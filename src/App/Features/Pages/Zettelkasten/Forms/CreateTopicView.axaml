<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Zettelkasten.Forms.CreateTopicView"
             xmlns:vm="using:Misa.Ui.Avalonia.Features.Pages.Zettelkasten.Forms"
             x:DataType="vm:CreateTopicViewModel">
    
    <StackPanel Classes="addpanel-body">

        <StackPanel Classes="addpanel-controls">
            <TextBlock Text="Name your Topic."
                       Classes="addpanel-text"/>

            <TextBox Classes="addpanel-oneliner"
                     Text="{Binding TopicTitle, Mode=TwoWay}" />
        </StackPanel>

    </StackPanel>
</UserControl>
