<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Zettelkasten"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Zettelkasten.TrashView"
             x:DataType="root:TrashViewModel">

    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBool"/>
    </UserControl.Resources>

    <StackPanel Spacing="0">

        <!-- Loading -->
        <TextBlock Text="Loading…"
                   IsVisible="{Binding IsLoading}"
                   Opacity="0.45"
                   Margin="0,8,0,0"/>

        <!-- Empty -->
        <TextBlock Text="Trash is empty."
                   IsVisible="{Binding IsEmpty}"
                   Opacity="0.45"
                   Margin="0,8,0,0"/>

        <!-- Hierarchical trash tree -->
        <TreeView x:Name="TrashTree"
                  ItemsSource="{Binding Entries}"
                  IsVisible="{Binding IsLoading,
                      Converter={x:Static converters:BooleanNotConverter.Instance}}">

            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.Styles>

            <TreeView.ItemTemplate>
                <TreeDataTemplate DataType="root:KnowledgeIndexNodeVm"
                                  ItemsSource="{Binding Children}">
                    <Border Padding="0,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BrushBorder}">
                        <Grid ColumnDefinitions="16,*,Auto,Auto" ColumnSpacing="8">

                            <!-- Workflow icon -->
                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                <Image Width="13" Height="13" Opacity="0.45"
                                       Source="{SvgImage /Assets/Icons/Common/folder.svg}"
                                       IsVisible="{Binding Workflow,
                                           Converter={x:Static converters:WorkflowEqualConverter.Instance},
                                           ConverterParameter=Topic}"/>
                                <Image Width="13" Height="13" Opacity="0.45"
                                       Source="{SvgImage /Assets/Icons/Shell/Navigation/scroll.svg}"
                                       IsVisible="{Binding Workflow,
                                           Converter={x:Static converters:WorkflowEqualConverter.Instance},
                                           ConverterParameter=Zettel}"/>
                            </Grid>

                            <!-- Title + deletion date -->
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Opacity="0.85"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding DeletedAtDisplay}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Opacity="0.35"
                                           IsVisible="{Binding DeletedAt,
                                               Converter={StaticResource NullToBool}}"/>
                            </StackPanel>

                            <!-- Restore -->
                            <Button Grid.Column="2"
                                    Command="{Binding $parent[TreeView].((root:TrashViewModel)DataContext).RestoreEntryCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center"
                                    Padding="8,4"
                                    Content="Restore"/>

                            <!-- Permanent delete -->
                            <Button Grid.Column="3"
                                    Command="{Binding $parent[TreeView].((root:TrashViewModel)DataContext).HardDeleteEntryCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center"
                                    Padding="8,4"
                                    Opacity="0.55"
                                    Content="Delete"/>

                        </Grid>
                    </Border>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>

        </TreeView>

    </StackPanel>

</UserControl>
