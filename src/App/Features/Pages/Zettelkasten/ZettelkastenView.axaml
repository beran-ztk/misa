<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Zettelkasten.ZettelkastenView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Zettelkasten"
             x:DataType="root:ZettelkastenViewModel">
    
    <Border Padding="10"
            Background="{StaticResource BrushPrimaryBackgroundLight}">
        <Grid ColumnDefinitions="300,*">

            <!-- Index -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushPrimaryBackgroundLight}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="Index" />
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                    <TextBox Text="{Binding TopicTitle, Mode=TwoWay}"/>
                    <Button Content="Create Topic"
                            Command="{Binding CreateTopicCommand}"/>
                    
                    <TreeView ItemsSource="{Binding Topics}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Title}" />
                                    <Button Classes="workspace-toolbar-icon"
                                            Click="InputElement_OnPointerPressed">
                                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                                    </Button>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </Border>

            <!-- Content / Overview -->
            <Border Grid.Column="1"
                    Background="{StaticResource BrushPrimaryBackgroundLight}">
                <TextBlock Text="Overview" />
            </Border>

        </Grid>
    </Border>

</UserControl>