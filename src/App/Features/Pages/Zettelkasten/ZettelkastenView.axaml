<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Zettelkasten"
             xmlns:conv="using:Misa.Ui.Avalonia.Common.Converters"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="700"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Zettelkasten.ZettelkastenView"
             x:DataType="root:ZettelkastenViewModel">

    <UserControl.Styles>
        <Style Selector="TreeView.zettelkasten-tree">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TreeViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>

        <Style Selector="Border.topic-row">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Border.topic-row:pointerover">
            <Setter Property="Background" Value="#0FFFFFFF" />
            <Setter Property="BorderBrush" Value="#14FFFFFF" />
        </Style>

        <Style Selector="TextBlock.topic-title">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        </Style>

        <Style Selector="Button.topic-add-button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.topic-row:pointerover Button.topic-add-button">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

        <Style Selector="Button.topic-add-button:pointerover">
            <Setter Property="Background" Value="#12FFFFFF" />
        </Style>

        <Style Selector="Button.topic-add-button Image">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="12" />
        </Style>
    </UserControl.Styles>

    <Border Padding="12"
            Background="{StaticResource BrushPrimaryBackgroundLight}">
        <Grid ColumnDefinitions="320,*"
              ColumnSpacing="0">

            <!-- Left: Index -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushPrimaryBackgroundLight}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0"
                    Padding="0,0,12,0">

                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Header -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="8"
                          Margin="0,0,0,8">
                        <TextBlock Grid.Column="0"
                                   Text="Knowledge Map"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextPrimary}" />

                        <Button Grid.Column="1"
                                Classes="workspace-toolbar-icon"
                                ToolTip.Tip="Add"
                                Click="Add_OnPointerPressed">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout>
                                    <MenuItem Header="Create Topic" Click="CreateTopicMenuItem_OnClick" />
                                    <MenuItem Header="Create Zettel" Click="CreateZettelMenuItem_OnClick" />
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                        </Button>

                        <Button Grid.Column="2"
                                Classes="workspace-toolbar-icon"
                                ToolTip.Tip="Refresh"
                                Command="{Binding RefreshWorkspaceCommand}">
                            <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="1"
                            VerticalAlignment="Top"
                            Margin="0,0,0,10"
                            Height="1"
                            Background="{StaticResource BrushBorder}"
                            Opacity="0.35" />

                    <!-- Tree -->
                    <ScrollViewer Grid.Row="2"
                                  Margin="0,12,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">

                        <TreeView Classes="zettelkasten-tree"
                                  ItemsSource="{Binding Index}"
                                  SelectionChanged="Tree_OnSelectionChanged">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <Border Classes="topic-row">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="6">

                                            <!-- Type icon -->
                                            <Panel Grid.Column="0">
                                                <Image IsVisible="{Binding Workflow, Converter={x:Static conv:WorkflowEqualConverter.Instance}, ConverterParameter=Topic}"
                                                       Source="{SvgImage /Assets/Icons/Common/folder.svg}"
                                                       Width="14" Height="14"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.65" />
                                                <Image IsVisible="{Binding Workflow, Converter={x:Static conv:WorkflowEqualConverter.Instance}, ConverterParameter=Zettel}"
                                                       Source="{SvgImage /Assets/Icons/Shell/Navigation/scroll.svg}"
                                                       Width="14" Height="14"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.65" />
                                            </Panel>

                                            <TextBlock Grid.Column="1"
                                                       Classes="topic-title"
                                                       Text="{Binding Title}" />

                                            <Button Grid.Column="2"
                                                    Classes="topic-add-button"
                                                    IsVisible="{Binding Workflow, Converter={x:Static conv:WorkflowEqualConverter.Instance}, ConverterParameter=Topic}"
                                                    Click="Add_OnPointerPressed">
                                                <FlyoutBase.AttachedFlyout>
                                                    <MenuFlyout>
                                                        <MenuItem Header="Create Topic" Click="CreateTopicMenuItem_OnClick" />
                                                        <MenuItem Header="Create Zettel" Click="CreateZettelMenuItem_OnClick" />
                                                    </MenuFlyout>
                                                </FlyoutBase.AttachedFlyout>
                                                <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right: Content -->
            <Border Grid.Column="1"
                    Background="{StaticResource BrushPrimaryBackgroundLight}"
                    Padding="20,0,0,0">

                <StackPanel>
                    <!-- Empty state -->
                    <TextBlock IsVisible="{Binding SelectedZettel, Converter={x:Static ObjectConverters.IsNull}}"
                               Text="Select a Zettel to view its content."
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Opacity="0.4"
                               Foreground="{StaticResource BrushTextPrimary}" />

                    <!-- Zettel detail -->
                    <Grid IsVisible="{Binding SelectedZettel, Converter={x:Static ObjectConverters.IsNotNull}}"
                          RowDefinitions="Auto,Auto">

                        <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedZettel.Title}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource BrushTextPrimary}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SaveStateLabel}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Opacity="0.5"
                                       Foreground="{StaticResource BrushTextPrimary}" />
                        </Grid>

                        <TextBox Grid.Row="1"
                                 Margin="0,12,0,0"
                                 Text="{Binding EditableContent, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="200"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 Watermark="Start writing…"
                                 Foreground="{StaticResource BrushTextPrimary}"
                                 LineHeight="22"
                                 FontSize="14" />
                    </Grid>
                </StackPanel>

            </Border>
        </Grid>
    </Border>
</UserControl>