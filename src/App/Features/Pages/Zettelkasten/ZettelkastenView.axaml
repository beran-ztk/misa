<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Zettelkasten"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="700"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Zettelkasten.ZettelkastenView"
             x:DataType="root:ZettelkastenViewModel">

   <Border Padding="12"
           Background="{StaticResource BrushPrimaryBackgroundLight}">
       <Grid ColumnDefinitions="320,*"
             ColumnSpacing="0">

           <!-- Left: Index -->
           <Border Grid.Column="0"
                   Background="{StaticResource BrushPrimaryBackgroundLight}"
                   BorderBrush="{StaticResource BrushBorder}"
                   BorderThickness="0,0,1,0"
                   Padding="0,0,12,0">

               
           </Border>

           <!-- Right: Content -->
           <Border Grid.Column="1"
                   Background="{StaticResource BrushPrimaryBackgroundLight}"
                   Padding="16,0,0,0">
               <StackPanel>
                   <!-- Empty state -->
                   <TextBlock Text="Select a Zettel to view its content."
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Opacity="0.4"
                              Foreground="{StaticResource BrushTextPrimary}" />
               </StackPanel>
           </Border>
       </Grid>
   </Border>
</UserControl>
