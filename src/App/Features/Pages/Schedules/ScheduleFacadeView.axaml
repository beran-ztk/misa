<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Schedules.ScheduleFacadeView"
             xmlns:schedules="clr-namespace:Misa.Contract.Items.Components.Schedules;assembly=Contract"
             xmlns:root1="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Schedules"
             x:DataType="root1:ScheduleFacadeViewModel">

  <UserControl.Styles>

      <!-- Neutralize default ListBox item background so card styles are authoritative -->
      <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
      </Style>
      <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
      </Style>

      <!-- Hover: subtle lift matching task cards -->
      <Style Selector="ListBoxItem:pointerover Border.schedule-card">
          <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}" />
          <Setter Property="BoxShadow" Value="0 4 16 0 #40000000"/>
      </Style>

      <!-- Selected: accent border only — no shadow, matches task card restraint -->
      <Style Selector="ListBoxItem:selected Border.schedule-card">
          <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
          <Setter Property="BorderThickness" Value="1.5"/>
      </Style>

      <!-- Badge: small pill in title row — quieter than before -->
      <Style Selector="Border.badge">
          <Setter Property="CornerRadius"    Value="{StaticResource CornerRadiusRound}"/>
          <Setter Property="Padding"         Value="6,2"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
      </Style>
      <Style Selector="TextBlock.badge-text">
          <Setter Property="FontSize" Value="10"/>
          <Setter Property="Opacity" Value="0.55"/>
          <Setter Property="LetterSpacing" Value="0.4"/>
      </Style>

      <!-- Chip: constraint detail pill -->
      <Style Selector="Border.chip">
          <Setter Property="CornerRadius" Value="5"/>
          <Setter Property="Padding" Value="7,3"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
          <Setter Property="Background" Value="#06FFFFFF"/>
      </Style>
      <Style Selector="TextBlock.chip-text">
          <Setter Property="FontSize" Value="11"/>
          <Setter Property="Opacity" Value="0.80"/>
      </Style>

      <!-- Muted: contextual meta (execution status, timezone) -->
      <Style Selector="TextBlock.muted">
          <Setter Property="Opacity" Value="0.50"/>
          <Setter Property="FontSize" Value="12"/>
      </Style>

  </UserControl.Styles>


    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right">
                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search schedules..."
                             Text="{Binding State.SearchText, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0"
                            Classes="workspace-toolbar-center" />

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Classes="workspace-toolbar-separator" />
            </Grid>
        </Border>

        <!-- Content -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding State.FilteredItems}"
                 SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                 Background="{StaticResource BrushPrimaryBackgroundLight}"
                 Padding="16,8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="schedules:ScheduleDto">

                  <Border Classes="schedule-card"
                          Padding="16,12"
                          BorderBrush="{StaticResource BrushBorder}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Background="{StaticResource BrushPrimaryBackground}"
                          Margin="0,0,0,8">

                    <StackPanel Spacing="0">

                      <!-- Title row: name + restriction badges -->
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="8"
                            Margin="0,0,0,4">
                        <TextBlock Text="{Binding Item.Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                          <Border Classes="badge" IsVisible="{Binding HasHardRestrictions}">
                            <TextBlock Classes="badge-text" Text="CONSTRAINED" />
                          </Border>
                          <Border Classes="badge" IsVisible="{Binding HasSoftRestrictions}">
                            <TextBlock Classes="badge-text" Text="LIMITED" />
                          </Border>
                        </StackPanel>
                      </Grid>

                      <!-- Meta row: execution status + timezone (quiet, contextual) -->
                      <Grid ColumnDefinitions="*,Auto"
                            Margin="0,0,0,8">
                        <TextBlock Text="{Binding ExecutionStatus}"
                                   Classes="muted" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Timezone}"
                                   Classes="muted" />
                      </Grid>

                      <!-- Divider -->
                      <Border Height="1"
                              Background="{StaticResource BrushBorder}"
                              Opacity="0.40"
                              Margin="0,0,0,8" />

                      <!-- Trigger summary — primary content statement -->
                      <TextBlock Text="{Binding TriggerSummary}"
                                 FontSize="13"
                                 Foreground="{StaticResource BrushTextSecondary}"
                                 TextWrapping="Wrap"
                                 LineHeight="20"
                                 Margin="0,0,0,8" />

                      <!-- Constraint chips (only when hard restrictions exist) -->
                      <WrapPanel ItemSpacing="4" LineSpacing="4"
                                 IsVisible="{Binding HasHardRestrictions}"
                                 Margin="0,0,0,8">
                        <Border Classes="chip" IsVisible="{Binding ConstraintTimeWindow, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Classes="chip-text" Text="{Binding ConstraintTimeWindow}" />
                        </Border>
                        <Border Classes="chip" IsVisible="{Binding ConstraintWeekdays, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Classes="chip-text" Text="{Binding ConstraintWeekdays}" />
                        </Border>
                        <Border Classes="chip" IsVisible="{Binding ConstraintMonths, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Classes="chip-text" Text="{Binding ConstraintMonths}" />
                        </Border>
                        <Border Classes="chip" IsVisible="{Binding ConstraintMonthDays, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Classes="chip-text" Text="{Binding ConstraintMonthDays}" />
                        </Border>
                      </WrapPanel>

                      <!-- Operational behaviour — quietest footnote -->
                      <TextBlock Text="{Binding OperationalBehaviour}"
                                 FontSize="11"
                                 Opacity="0.40"
                                 TextWrapping="Wrap" />

                    </StackPanel>
                  </Border>

                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
    </Grid>
</UserControl>
