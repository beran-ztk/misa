<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Schedules.ScheduleFacadeView"
             xmlns:schedules="clr-namespace:Misa.Contract.Items.Components.Schedules;assembly=Contract"
             xmlns:root1="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Schedules"
             x:DataType="root1:ScheduleFacadeViewModel">

    <UserControl.Styles>

        <!-- Neutralize ListBox item backgrounds — card styles are authoritative -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── Schedule card defaults ──────────────────────────────────── -->
        <Style Selector="Border.schedule-card">
            <Setter Property="Background"      Value="{StaticResource BrushPrimaryBackground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Hover: border lifts -->
        <Style Selector="ListBoxItem:pointerover Border.schedule-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
        </Style>

        <!-- Selected: accent border, matching task card restraint -->
        <Style Selector="ListBoxItem:selected Border.schedule-card">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover Border.schedule-card">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── Status badges ───────────────────────────────────────────── -->
        <!-- Structure (CornerRadius, BorderThickness, VerticalAlignment, FontSize) from Controls.axaml pill base -->
        <Style Selector="Border.schedule-badge">
            <Setter Property="Padding"     Value="6,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        </Style>
        <Style Selector="TextBlock.schedule-badge-text">
            <Setter Property="Opacity"       Value="0.5"/>
            <Setter Property="LetterSpacing" Value="0.4"/>
        </Style>

        <!-- ── Constraint chips ────────────────────────────────────────── -->
        <Style Selector="Border.schedule-chip">
            <Setter Property="CornerRadius"    Value="{StaticResource CornerRadiusControl}"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="Background"      Value="#06FFFFFF"/>
        </Style>
        <Style Selector="TextBlock.schedule-chip-text">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="Opacity"  Value="0.75"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Toolbar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Add (primary action only — no Refresh) -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}"/>
                    </Button>
                </StackPanel>

                <!-- Search -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right">
                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search schedules..."
                             Text="{Binding State.SearchText, Mode=TwoWay}"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Classes="workspace-toolbar-separator"/>
            </Grid>
        </Border>

        <!-- ── Content ──────────────────────────────────────────────────── -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding State.FilteredItems}"
                 SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                 Background="{StaticResource BrushPrimaryBackgroundLight}"
                 Padding="10,8"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="schedules:ScheduleDto">

                    <Border Classes="schedule-card"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,0,0,4">

                        <StackPanel Spacing="3">

                            <!-- Title + status badges -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Item.Title}"
                                           FontSize="{StaticResource FontSizeMedium}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           Opacity="0.85"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <Border Classes="schedule-badge state-badge"
                                            IsVisible="{Binding HasHardRestrictions}">
                                        <TextBlock Classes="schedule-badge-text badge-text"
                                                   Text="CONSTRAINED"/>
                                    </Border>
                                    <Border Classes="schedule-badge state-badge"
                                            IsVisible="{Binding HasSoftRestrictions}">
                                        <TextBlock Classes="schedule-badge-text badge-text"
                                                   Text="LIMITED"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Trigger summary + timezone -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TriggerSummary}"
                                           FontSize="{StaticResource FontSizeAverage}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Timezone}"
                                           FontSize="{StaticResource FontSizeAverage}"
                                           Foreground="{StaticResource BrushTextFaded}"
                                           Opacity="0.75"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Execution status -->
                            <TextBlock Text="{Binding ExecutionStatus}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{StaticResource BrushTextFaded}"
                                       Opacity="0.75"/>

                            <!-- Constraint chips — only when hard restrictions exist -->
                            <WrapPanel ItemSpacing="4" LineSpacing="3"
                                       IsVisible="{Binding HasHardRestrictions}"
                                       Margin="0,2,0,0">
                                <Border Classes="schedule-chip"
                                        IsVisible="{Binding ConstraintTimeWindow,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Classes="schedule-chip-text"
                                               Text="{Binding ConstraintTimeWindow}"/>
                                </Border>
                                <Border Classes="schedule-chip"
                                        IsVisible="{Binding ConstraintWeekdays,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Classes="schedule-chip-text"
                                               Text="{Binding ConstraintWeekdays}"/>
                                </Border>
                                <Border Classes="schedule-chip"
                                        IsVisible="{Binding ConstraintMonths,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Classes="schedule-chip-text"
                                               Text="{Binding ConstraintMonths}"/>
                                </Border>
                                <Border Classes="schedule-chip"
                                        IsVisible="{Binding ConstraintMonthDays,
                                            Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Classes="schedule-chip-text"
                                               Text="{Binding ConstraintMonthDays}"/>
                                </Border>
                            </WrapPanel>

                        </StackPanel>
                    </Border>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>
</UserControl>
