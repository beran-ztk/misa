<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Tasks.TaskFacadeView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:filters="clr-namespace:Misa.Ui.Avalonia.Common.Components.FilterDropdown"
             xmlns:tasks="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Tasks"
             x:DataType="tasks:TaskFacadeViewModel">

    <UserControl.Resources>
        <converters:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
        <converters:ItemAgeConverter x:Key="ItemAgeConverter" />
        <converters:DeadlineShortConverter x:Key="DeadlineShortConverter" />
        <converters:IsOverdueConverter x:Key="IsOverdueConverter" />
        <converters:IsDueSoonConverter x:Key="IsDueSoonConverter" />
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- ── ListBox item reset ─────────────────────────────────── -->
        <!--
            Base setters (Padding=0, Background=Transparent, Cursor=Hand) are
            covered by the global ListBoxItem style; only the hover/selected
            Transparent overrides need to be here since the global base shows
            BrushSubtleOverlay / BrushSelectedOverlay and cards own their feedback.
        -->
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ── Card base defaults (must live here, not as inline attributes,   -->
        <!--    so that :pointerover / :selected selectors can override them) -->
        <Style Selector="Border.task-card">
            <Setter Property="Background"      Value="{StaticResource BrushPrimaryBackground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
        </Style>

        <!-- ── Card hover / selected states ─────────────────────────── -->
        <!--
            Visual hierarchy: Selected > Hover > Default
            Hover    — border lifts to BrushBorderLight
            Selected — accent border (1.5px) + very subtle accent background tint
        -->
        <Style Selector="ListBoxItem:pointerover Border.task-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.task-card">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
        </Style>
        <!-- Selected takes priority: prevent hover from overriding the accent border -->
        <Style Selector="ListBoxItem:selected:pointerover Border.task-card">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="0,1,1,1"/>
        </Style>

        <!-- ── View mode icon buttons ────────────────────────────────── -->
        <Style Selector="Button.workspace-toolbar-icon.view-active">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.workspace-toolbar-icon.view-active /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>

        <!-- ── Workspace mode segmented control ──────────────────────── -->

        <!--
            Segment button base — sits inside a container Border.
            btn-seg covers: Foreground=Faded, CornerRadius=3, :pointerover/pressed overlays.
            Local additions: fixed Height/Padding, hover step to Secondary, filled active bg.
        -->
        <Style Selector="Button.workspace-mode-seg">
            <Setter Property="Height"   Value="22"/>
            <Setter Property="Padding"  Value="12,0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeAverage}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushSelectedOverlay}"/>
            </Style>
        </Style>

        <!-- Active segment — opaque fill (overrides btn-seg.active SelectedOverlay) -->
        <Style Selector="Button.workspace-mode-seg.active">
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            </Style>
        </Style>

        <!--
            Deleted segment — when active: very subtle muted-red text.
            Not loud. Just a quiet signal that this is a critical zone.
        -->
        <Style Selector="Button.workspace-mode-seg-deleted.active">
            <Setter Property="Foreground" Value="#C87878"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="#14F44336"/>
            </Style>
        </Style>

        <!-- ── Deleted accent bar override ───────────────────────────── -->
        <Style Selector="Border.task-card-deleted-bar">
            <Setter Property="Background" Value="#60F44336"/>
        </Style>

        <!-- ── Signal chips ──────────────────────────────────────────── -->
        <Style Selector="Border.signal-chip">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style Selector="Border.signal-chip TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.signal-chip.neutral">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
        <Style Selector="Border.signal-chip.neutral TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
        </Style>
        <Style Selector="Border.signal-chip.deadline">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
        <Style Selector="Border.signal-chip.deadline TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        </Style>
        <Style Selector="Border.signal-chip.overdue">
            <Setter Property="Background" Value="#3A1A1A"/>
        </Style>
        <Style Selector="Border.signal-chip.overdue TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
        </Style>
        <Style Selector="Border.signal-chip.due-soon">
            <Setter Property="Background" Value="#3A2E10"/>
        </Style>
        <Style Selector="Border.signal-chip.due-soon TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushWarning}"/>
        </Style>

        <!-- ── Sort field trigger button ─────────────────────────────── -->
        <Style Selector="Button.sort-field-trigger">
            <Setter Property="Height"     Value="22"/>
            <Setter Property="Padding"    Value="8,0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"   Value="{StaticResource FontSizeAverage}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
                <Setter Property="Background"      Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
                <Setter Property="Background"  Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            </Style>
        </Style>

        <!-- ── Sort option items inside flyout ───────────────────────── -->
        <!-- btn-menu-item covers: Foreground, FontSize, Stretch/Left alignment, hover states -->
        <Style Selector="Button.sort-option">
            <Setter Property="Padding" Value="9,6"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="3"/>
            </Style>
        </Style>
        <!-- Active sort option — accent-colored -->
        <Style Selector="Button.sort-option.sort-active">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        </Style>

        <!-- ── Card inline action links ──────────────────────────────── -->
        <!--
            Text-weight action triggers placed in the card header.
            No visible border at rest — hover gives a subtle fill.
        -->
        <Style Selector="Button.card-action-link">
            <Setter Property="Padding"  Value="6,2"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="3"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushHoverOverlay}"/>
            </Style>
        </Style>

        <!-- Restore: muted at rest, secondary on hover -->
        <Style Selector="Button.card-action-link.restore">
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#0AFFFFFF"/>
            </Style>
        </Style>

        <!-- Delete permanently: muted red at rest, full red on hover -->
        <Style Selector="Button.card-action-link.danger">
            <Setter Property="Foreground" Value="#A05858"/>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#10F44336"/>
            </Style>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0 left: quick actions -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}"
                            IsVisible="{Binding State.IsActiveMode}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Row 0 right: search -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right">
                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search tasks..."
                             Text="{Binding State.SearchText, Mode=TwoWay}" />
                </StackPanel>

                <!--
                    Row 1: workspace mode segmented control (left) + layout toggle (right).
                    Container Border unifies the segments visually.
                    Active segment gets a filled background; deleted active uses a subtle red tint.
                -->
                <Border Grid.Row="1" Grid.Column="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrushPrimaryBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="2">
                    <StackPanel Orientation="Horizontal" Spacing="1">
                        <Button Classes="workspace-mode-seg btn-seg"
                                Classes.active="{Binding State.IsActiveMode}"
                                Command="{Binding SetActiveModeCommand}"
                                Content="Active"/>
                        <Button Classes="workspace-mode-seg btn-seg"
                                Classes.active="{Binding State.IsArchivedMode}"
                                Command="{Binding SetArchivedModeCommand}"
                                Content="Archived"/>
                        <Button Classes="workspace-mode-seg workspace-mode-seg-deleted btn-seg"
                                Classes.active="{Binding State.IsDeletedMode}"
                                Command="{Binding SetDeletedModeCommand}"
                                Content="Deleted"/>
                    </StackPanel>
                </Border>

                <!-- Row 1 right: layout toggle — segmented control matching workspace-mode style -->
                <Border Grid.Row="1" Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrushPrimaryBackground}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="2">
                    <StackPanel Orientation="Horizontal" Spacing="1">
                        <Button Classes="workspace-mode-seg btn-seg"
                                Classes.active="{Binding State.IsCardView}"
                                Command="{Binding SetCardViewCommand}"
                                Content="Card"/>
                        <Button Classes="workspace-mode-seg btn-seg"
                                Classes.active="{Binding State.IsListView}"
                                Command="{Binding SetListViewCommand}"
                                Content="List"/>
                    </StackPanel>
                </Border>

                <!-- Row 2 left: filters -->
                <StackPanel Grid.Row="2" Grid.Column="0"
                            Classes="workspace-toolbar-center">

                    <filters:FilterDropdownView
                        DataContext="{Binding State.PriorityFilter}"/>

                    <filters:FilterDropdownView
                        DataContext="{Binding State.StateFilter}"/>

                    <filters:FilterDropdownView
                        DataContext="{Binding State.CategoryFilter}"/>

                </StackPanel>

                <!--
                    Row 2 right: sort group — [Sort label] [field ▾ | ↑↓] in a single container.
                    Uses the same segmented-control border as the workspace/layout toggles so
                    the field picker and direction button read as one coherent control.
                -->
                <StackPanel Grid.Row="2" Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="5"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <TextBlock Text="Sort by"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center"/>

                    <Border Background="{StaticResource BrushPrimaryBackground}"
                            BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="2">
                        <StackPanel Orientation="Horizontal" Spacing="1">

                            <!-- Field picker -->
                            <Button Classes="workspace-mode-seg btn-seg">
                                <TextBlock Text="{Binding State.SortFieldLabel}"
                                           VerticalAlignment="Center"/>
                                
                                <Button.Flyout>
                                    <Flyout Placement="Bottom"
                                            ShowMode="TransientWithDismissOnPointerMoveAway">
                                        <Border Background="{StaticResource BrushPrimaryBackground}"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                BoxShadow="0 4 16 2 #50000000"
                                                MinWidth="130"
                                                Padding="2">
                                            <StackPanel Spacing="1">
                                                <Button Classes="sort-option btn-menu-item"
                                                        Classes.sort-active="{Binding State.IsSortByCreated}"
                                                        Command="{Binding SetSortCreatedCommand}"
                                                        Content="Created"/>
                                                <Button Classes="sort-option btn-menu-item"
                                                        Classes.sort-active="{Binding State.IsSortByTitle}"
                                                        Command="{Binding SetSortTitleCommand}"
                                                        Content="Title"/>
                                                <Button Classes="sort-option btn-menu-item"
                                                        Classes.sort-active="{Binding State.IsSortByState}"
                                                        Command="{Binding SetSortStateCommand}"
                                                        Content="State"/>
                                            </StackPanel>
                                        </Border>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>

                            <!-- Direction toggle -->
                            <Button Classes="workspace-mode-seg btn-seg"
                                    Padding="8,0"
                                    Command="{Binding ToggleSortDirectionCommand}">
                                <TextBlock Text="{Binding State.SortDirectionGlyph}"
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                            </Button>

                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Row 3: meta summary -->
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding State.MetaSummary}"
                           Classes="workspace-meta-summary"/>

                <!-- Row 4: separator -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                        Classes="workspace-toolbar-separator" />
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- List / table view -->
            <Border Classes="workspace-content-frame"
                    IsVisible="{Binding State.IsListView}">
                <DataGrid Classes="workspace-datagrid"
                          HorizontalAlignment="Center"
                          ItemsSource="{Binding State.FilteredItems}"
                          SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="False"
                          SelectionMode="Extended"
                          IsReadOnly="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Title" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Item.Title}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="State"
                                            Binding="{Binding Activity.State}"
                                            Width="120" />
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="120" />
                        <DataGridTemplateColumn Header="Priority" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding Activity.Priority,
                                                     Converter={StaticResource PriorityToBrushConverter}}" />
                                        <TextBlock Text="{Binding Activity.Priority}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Deadline"
                                            Binding="{Binding Activity.DueAt,
                                                Converter={StaticResource DeadlineShortConverter}}"
                                            Width="100" />
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding Item.CreatedAt,
                                                Converter={StaticResource UtcToLocalConverter},
                                                StringFormat='dd.MM.yyyy'}"
                                            Width="100" />
                        <DataGridTextColumn Header="Modified"
                                            Binding="{Binding Item.ModifiedAt,
                                                Converter={StaticResource UtcToLocalConverter},
                                                StringFormat='dd.MM.yyyy'}"
                                            Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Card view -->
            <ListBox ItemsSource="{Binding State.FilteredItems}"
                     SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                     IsVisible="{Binding State.IsCardView}"
                     Background="{StaticResource BrushPrimaryBackgroundLight}"
                     Padding="10,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <!--
                            Card:
                              Outer Border (CornerRadius, ClipToBounds, opacity per mode)
                                Grid [5px accent bar | content]
                                  content: title row + meta row + chips row

                            Title row (Row 1):
                              Left  — title text
                              Right — deadline chip  (active mode, when DueAt set)
                                    — action links   (archived / deleted modes)
                        -->
                        <Border Classes="task-card"
                                CornerRadius="6"
                                Padding="0"
                                Margin="0,0,0,6"
                                ClipToBounds="True"
                                Opacity="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.CardOpacity}">

                            <Grid ColumnDefinitions="5,*">

                                <!-- Priority accent bar; turns muted red in deleted mode -->
                                <Border Grid.Column="0"
                                        Background="{Binding Activity.Priority,
                                            Converter={StaticResource PriorityToBrushConverter}}"
                                        Classes.task-card-deleted-bar="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.IsDeletedMode}"/>

                                <!-- Card content -->
                                <StackPanel Grid.Column="1"
                                            Margin="10,9,10,9"
                                            Spacing="4">

                                    <!-- Row 1: Title  |  deadline chip –or– action links -->
                                    <Grid ColumnDefinitions="*,Auto">

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Item.Title}"
                                                   FontSize="{StaticResource FontSizeMedium}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   Opacity="0.8"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!--
                                            Active mode: deadline chip (only when DueAt is set).
                                            The outer wrapper collapses in non-active modes so it
                                            never competes for space with the action links.
                                        -->
                                        <Border Grid.Column="1"
                                                VerticalAlignment="Top"
                                                Margin="8,1,0,0"
                                                IsVisible="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.IsActiveMode}">
                                            <Border Classes="signal-chip deadline"
                                                    Classes.overdue="{Binding Activity.DueAt,
                                                        Converter={StaticResource IsOverdueConverter}}"
                                                    Classes.due-soon="{Binding Activity.DueAt,
                                                        Converter={StaticResource IsDueSoonConverter}}"
                                                    IsVisible="{Binding Activity.DueAt,
                                                        Converter={StaticResource NullToBoolConverter}}">
                                                <TextBlock Text="{Binding Activity.DueAt,
                                                               Converter={StaticResource DeadlineShortConverter}}"/>
                                            </Border>
                                        </Border>

                                        <!--
                                            Archived / Deleted modes: inline action links.
                                            Restore is shown in both; Delete permanently is deleted-only.
                                            Text-weight style — no border, minimal visual footprint.
                                        -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="0"
                                                    VerticalAlignment="Top"
                                                    Margin="6,0,0,0"
                                                    IsVisible="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.IsNonActiveMode}">

                                            <Button Classes="card-action-link restore"
                                                    Command="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).RestoreItemCommand}"
                                                    CommandParameter="{Binding Item.Id}"
                                                    Content="Restore"/>

                                            <!-- Divider + danger action — deleted mode only -->
                                            <TextBlock Text="·"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextFaded}"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0"
                                                       Opacity="0.5"
                                                       IsVisible="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.IsDeletedMode}"/>

                                            <Button Classes="card-action-link danger"
                                                    IsVisible="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).State.IsDeletedMode}"
                                                    Command="{Binding $parent[ListBox].((tasks:TaskFacadeViewModel)DataContext).HardDeleteItemCommand}"
                                                    CommandParameter="{Binding Item.Id}"
                                                    Content="Delete permanently"/>

                                        </StackPanel>

                                    </Grid>

                                    <!-- Row 2: State · Category · Priority  |  Created date -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding Activity.State}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextSecondary}"/>
                                            <TextBlock Text="·"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextFaded}"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextSecondary}"/>
                                            <TextBlock Text="·"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextFaded}"/>
                                            <TextBlock Text="{Binding Activity.Priority}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       Opacity="0.7"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Item.CreatedAt,
                                                       Converter={StaticResource UtcToLocalConverter},
                                                       StringFormat='dd MMM'}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   IsVisible="{Binding Item.CreatedAt,
                                                       Converter={StaticResource NullToBoolConverter}}"/>
                                    </Grid>

                                    <!-- Row 3: age signal — only rendered when contextually relevant -->
                                    <Border Classes="signal-chip neutral"
                                            IsVisible="{Binding Item.CreatedAt,
                                                Converter={StaticResource ItemAgeConverter}}">
                                        <TextBlock Text="{Binding Item.CreatedAt,
                                                       Converter={StaticResource ItemAgeConverter}}"/>
                                    </Border>

                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>
    </Grid>
</UserControl>
