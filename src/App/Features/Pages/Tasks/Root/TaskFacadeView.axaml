<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Tasks.Root.TaskFacadeView"
             MinWidth="500"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Tasks.Root"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             x:DataType="root:TaskFacadeViewModel">

    <UserControl.Resources>
        <converters:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
        <converters:GreaterThanConverter x:Key="GreaterThanConverter" />
        <converters:LessOrEqualConverter x:Key="LessOrEqualConverter" />
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover Border.task-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
            <Setter Property="BoxShadow" Value="0 4 16 0 #40000000"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.task-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar (2 rows) -->
        <Border Grid.Row="0"
                Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0: Quick actions (left) -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>

                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Row 0: Search (right) -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right">
                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search tasks..."
                             Text="{Binding State.SearchText, Mode=TwoWay}" />
                </StackPanel>

                <!-- Row 1: Filters (left) -->
                <StackPanel Grid.Row="1" Grid.Column="0"
                            Classes="workspace-toolbar-center">
                    <ToggleButton x:Name="PriorityFilterButton"
                                  Classes="workspace-toolbar-filter-trigger">
                        <TextBlock Text="Priority  ▾" />
                    </ToggleButton>

                    <Popup PlacementTarget="{Binding ElementName=PriorityFilterButton}"
                           IsOpen="{Binding IsChecked, ElementName=PriorityFilterButton}"
                           Placement="Bottom">
                        <Border Classes="filter-popup-frame">
                            <ItemsControl ItemsSource="{Binding State.PriorityFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding ActivityPriority}"
                                                  IsChecked="{Binding IsSelected}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>

                    <ToggleButton x:Name="StateFilterButton"
                                  Classes="workspace-toolbar-filter-trigger">
                        <TextBlock Text="State  ▾" />
                    </ToggleButton>

                    <Popup PlacementTarget="{Binding ElementName=StateFilterButton}"
                           IsOpen="{Binding IsChecked, ElementName=StateFilterButton}"
                           Placement="Bottom">
                        <Border Classes="filter-popup-frame">
                            <ItemsControl ItemsSource="{Binding State.StateFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding ActivityState}"
                                                  IsChecked="{Binding IsSelected}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>

                    <ToggleButton x:Name="CategoryFilterButton"
                                  Classes="workspace-toolbar-filter-trigger">
                        <TextBlock Text="Category  ▾" />
                    </ToggleButton>

                    <Popup PlacementTarget="{Binding ElementName=CategoryFilterButton}"
                           IsOpen="{Binding IsChecked, ElementName=CategoryFilterButton}"
                           Placement="Bottom">
                        <Border Classes="filter-popup-frame">
                            <ItemsControl ItemsSource="{Binding State.CategoryFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding TaskCategory}"
                                                  IsChecked="{Binding IsSelected}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- Thin separator -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="workspace-toolbar-separator" />
            </Grid>
            
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1"
              x:Name="ContentRoot">

            <!-- Table -->
            <Border Classes="workspace-content-frame"
                    IsVisible="{Binding #ContentRoot.Bounds.Width, Converter={StaticResource GreaterThanConverter}, ConverterParameter=900}">
        
                <DataGrid Classes="workspace-datagrid"
                          HorizontalAlignment="Center"
                          ItemsSource="{Binding State.FilteredItems}"
                          SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          IsReadOnly="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Title" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Item.Title}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="State" Binding="{Binding Activity.State}" Width="120" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120" />

                        <DataGridTemplateColumn Header="Priority" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding Activity.Priority, Converter={StaticResource PriorityToBrushConverter}}" />
                                        <TextBlock Text="{Binding Activity.Priority}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding Item.CreatedAt,
                                                Converter={StaticResource UtcToLocalConverter},
                                                StringFormat='dd.MM.yyyy HH:mm'}"
                                            Width="180" />

                    </DataGrid.Columns>

                </DataGrid>
        
            </Border>

            <!-- Card View -->
            <ListBox ItemsSource="{Binding State.FilteredItems}"
                     SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                     IsVisible="{Binding #ContentRoot.Bounds.Width, Converter={StaticResource LessOrEqualConverter}, ConverterParameter=900}"
                     Background="{StaticResource BrushPrimaryBackgroundLight}"
                     Padding="18,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                            <Border Classes="task-card"
                                    Background="{StaticResource BrushPrimaryBackground}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14,12"
                                    Margin="0,0,0,8">

                                <StackPanel Spacing="0">

                                    <!-- Title -->
                                    <TextBlock Text="{Binding Item.Title}"
                                               FontSize="{StaticResource FontSizeMedium}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushTextPrimary}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               Margin="0,0,0,10" />

                                    <!-- Divider -->
                                    <Border Height="1"
                                            Background="{StaticResource BrushBorder}"
                                            Margin="0,0,0,10" />

                                    <!-- Properties -->
                                    <Grid ColumnDefinitions="80,*"
                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                          RowSpacing="6">

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="State"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Activity.State}"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Category"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding Category}"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Priority"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Row="2" Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Ellipse Width="7" Height="7"
                                                     Fill="{Binding Activity.Priority, Converter={StaticResource PriorityToBrushConverter}}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Activity.Priority}"
                                                       FontSize="{StaticResource FontSizeAverage}"
                                                       Foreground="{StaticResource BrushTextSecondary}" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="Created"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding Item.CreatedAt, Converter={StaticResource UtcToLocalConverter}, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontSize="{StaticResource FontSizeAverage}"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   VerticalAlignment="Center" />

                                    </Grid>

                                </StackPanel>
                            </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>
    </Grid>
</UserControl>
