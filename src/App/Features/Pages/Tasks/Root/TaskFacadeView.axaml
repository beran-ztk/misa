<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Tasks.Root.TaskFacadeView"
             MinWidth="500"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Tasks.Root"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:filters="clr-namespace:Misa.Ui.Avalonia.Common.Components.FilterDropdown"
             x:DataType="root:TaskFacadeViewModel">

    <UserControl.Resources>
        <converters:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
        <converters:ItemAgeConverter x:Key="ItemAgeConverter" />
        <converters:DeadlineShortConverter x:Key="DeadlineShortConverter" />
        <converters:IsOverdueConverter x:Key="IsOverdueConverter" />
        <converters:IsDueSoonConverter x:Key="IsDueSoonConverter" />
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- ListBox item reset -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Card hover / selected states -->
        <Style Selector="ListBoxItem:pointerover Border.task-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.task-card">
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <!-- View mode toggle: active state for toolbar icon buttons -->
        <Style Selector="Button.workspace-toolbar-icon.view-active">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.workspace-toolbar-icon.view-active /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>

        <!-- ── Workspace mode toggle ────────────────────────────── -->
        <Style Selector="Button.workspace-mode-btn">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeAverage}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            </Style>
        </Style>

        <!-- Active mode button — accent -->
        <Style Selector="Button.workspace-mode-btn.mode-on">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            </Style>
        </Style>

        <!-- Deleted mode button — danger tone when active -->
        <Style Selector="Button.workspace-mode-btn.mode-on.mode-danger">
            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="BorderBrush" Value="{StaticResource BrushError}"/>
            </Style>
        </Style>

        <!-- Deleted accent bar — overrides priority color with error red -->
        <Style Selector="Border.task-card-deleted-bar">
            <Setter Property="Background" Value="#7DF44336"/>
        </Style>

        <!-- ── Signal chips ─────────────────────────────────────── -->
        <Style Selector="Border.signal-chip">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style Selector="Border.signal-chip TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.signal-chip.neutral">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
        <Style Selector="Border.signal-chip.neutral TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
        </Style>
        <Style Selector="Border.signal-chip.deadline">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
        <Style Selector="Border.signal-chip.deadline TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        </Style>
        <Style Selector="Border.signal-chip.overdue">
            <Setter Property="Background" Value="#3A1A1A"/>
        </Style>
        <Style Selector="Border.signal-chip.overdue TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
        </Style>
        <Style Selector="Border.signal-chip.due-soon">
            <Setter Property="Background" Value="#3A2E10"/>
        </Style>
        <Style Selector="Border.signal-chip.due-soon TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushWarning}"/>
        </Style>

        <!-- ── Card action buttons ──────────────────────────────── -->
        <Style Selector="Button.card-action">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="3"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </Style>

        <Style Selector="Button.card-action.restore">
            <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="BorderBrush" Value="{StaticResource BrushSuccess}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#1A4CAF50"/>
            </Style>
        </Style>

        <Style Selector="Button.card-action.danger">
            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="BorderBrush" Value="#60F44336"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#1AF44336"/>
            </Style>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0 left: quick actions -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}"
                            IsVisible="{Binding State.IsActiveMode}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Row 0 right: view toggle + search -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right"
                            Spacing="8">

                    <!-- View mode toggle -->
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button Classes="workspace-toolbar-icon"
                                Classes.view-active="{Binding State.IsCardView}"
                                Command="{Binding SetCardViewCommand}"
                                ToolTip.Tip="Card view">
                            <Image Source="{SvgImage /Assets/Icons/Staging/tabs.svg}" />
                        </Button>
                        <Button Classes="workspace-toolbar-icon"
                                Classes.view-active="{Binding State.IsListView}"
                                Command="{Binding SetListViewCommand}"
                                ToolTip.Tip="List view">
                            <Image Source="{SvgImage /Assets/Icons/Shell/Navigation/list-dashes.svg}" />
                        </Button>
                    </StackPanel>

                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search tasks..."
                             Text="{Binding State.SearchText, Mode=TwoWay}" />
                </StackPanel>

                <!-- Row 1: workspace mode toggle -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button Classes="workspace-mode-btn"
                            Classes.mode-on="{Binding State.IsActiveMode}"
                            Command="{Binding SetActiveModeCommand}"
                            Content="Active"/>
                    <Button Classes="workspace-mode-btn"
                            Classes.mode-on="{Binding State.IsArchivedMode}"
                            Command="{Binding SetArchivedModeCommand}"
                            Content="Archived"/>
                    <Button Classes="workspace-mode-btn mode-danger"
                            Classes.mode-on="{Binding State.IsDeletedMode}"
                            Command="{Binding SetDeletedModeCommand}"
                            Content="Deleted"/>
                </StackPanel>

                <!-- Row 2: filters -->
                <StackPanel Grid.Row="2" Grid.Column="0"
                            Classes="workspace-toolbar-center">

                    <filters:FilterDropdownView
                        DataContext="{Binding State.PriorityFilter}"/>

                    <filters:FilterDropdownView
                        DataContext="{Binding State.StateFilter}"/>

                    <filters:FilterDropdownView
                        DataContext="{Binding State.CategoryFilter}"/>

                </StackPanel>

                <!-- Row 3: meta summary -->
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding State.MetaSummary}"
                           Classes="workspace-meta-summary"/>

                <!-- Row 4: separator -->
                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                        Classes="workspace-toolbar-separator" />
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- List / table view -->
            <Border Classes="workspace-content-frame"
                    IsVisible="{Binding State.IsListView}">
                <DataGrid Classes="workspace-datagrid"
                          HorizontalAlignment="Center"
                          ItemsSource="{Binding State.FilteredItems}"
                          SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          IsReadOnly="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Title" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Item.Title}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="State"
                                            Binding="{Binding Activity.State}"
                                            Width="120" />
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="120" />
                        <DataGridTemplateColumn Header="Priority" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding Activity.Priority,
                                                     Converter={StaticResource PriorityToBrushConverter}}" />
                                        <TextBlock Text="{Binding Activity.Priority}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Deadline"
                                            Binding="{Binding Activity.DueAt,
                                                Converter={StaticResource DeadlineShortConverter}}"
                                            Width="100" />
                        <DataGridTextColumn Header="Modified"
                                            Binding="{Binding Item.ModifiedAt,
                                                Converter={StaticResource UtcToLocalConverter},
                                                StringFormat='dd.MM.yyyy'}"
                                            Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Card view -->
            <ListBox x:Name="TaskCardList"
                     ItemsSource="{Binding State.FilteredItems}"
                     SelectedItem="{Binding State.SelectedItem, Mode=TwoWay}"
                     IsVisible="{Binding State.IsCardView}"
                     Background="{StaticResource BrushPrimaryBackgroundLight}"
                     Padding="10,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <!--
                            Card structure:
                            Outer Border (CornerRadius, ClipToBounds) with zero padding
                              Grid cols: [3px accent bar | content]
                        -->
                        <Border Classes="task-card"
                                Background="{StaticResource BrushPrimaryBackground}"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="0"
                                Margin="0,0,0,6"
                                ClipToBounds="True"
                                Opacity="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).State.CardOpacity}">

                            <Grid ColumnDefinitions="5,*">

                                <!-- Priority accent bar (turns red in deleted mode) -->
                                <Border Grid.Column="0"
                                        Background="{Binding Activity.Priority,
                                            Converter={StaticResource PriorityToBrushConverter}}"
                                        Classes.task-card-deleted-bar="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).State.IsDeletedMode}"/>

                                <!-- Card content -->
                                <StackPanel Grid.Column="1"
                                            Margin="10,9,12,9"
                                            Spacing="4">

                                    <!-- Row 1: Title | Deadline chip -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Item.Title}"
                                                   FontSize="{StaticResource FontSizeMedium}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   Opacity="0.8"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <Border Grid.Column="1"
                                                Classes="signal-chip deadline"
                                                Classes.overdue="{Binding Activity.DueAt,
                                                    Converter={StaticResource IsOverdueConverter}}"
                                                Classes.due-soon="{Binding Activity.DueAt,
                                                    Converter={StaticResource IsDueSoonConverter}}"
                                                VerticalAlignment="Top"
                                                Margin="8,1,0,0"
                                                IsVisible="{Binding Activity.DueAt,
                                                    Converter={StaticResource NullToBoolConverter}}">
                                            <TextBlock Text="{Binding Activity.DueAt,
                                                           Converter={StaticResource DeadlineShortConverter}}"/>
                                        </Border>
                                    </Grid>

                                    <!-- Row 2: State · Category | Modified date -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding Activity.State}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextSecondary}"/>
                                            <TextBlock Text="·"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextFaded}"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextSecondary}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Item.ModifiedAt,
                                                       Converter={StaticResource UtcToLocalConverter},
                                                       StringFormat='dd MMM'}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{StaticResource BrushTextFaded}"
                                                   IsVisible="{Binding Item.ModifiedAt,
                                                       Converter={StaticResource NullToBoolConverter}}"/>
                                    </Grid>

                                    <!-- Row 3: Signal chips (age) -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Classes="signal-chip neutral"
                                                IsVisible="{Binding Item.CreatedAt,
                                                    Converter={StaticResource ItemAgeConverter}}">
                                            <TextBlock Text="{Binding Item.CreatedAt,
                                                           Converter={StaticResource ItemAgeConverter}}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Row 4: Action buttons (Archived / Deleted modes only) -->
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="0,4,0,0"
                                                IsVisible="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).State.IsNonActiveMode}">

                                        <Button Classes="card-action restore"
                                                Command="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).RestoreItemCommand}"
                                                CommandParameter="{Binding Item.Id}"
                                                Content="Restore"/>

                                        <Button Classes="card-action danger"
                                                IsVisible="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).State.IsDeletedMode}"
                                                Command="{Binding $parent[ListBox].((root:TaskFacadeViewModel)DataContext).HardDeleteItemCommand}"
                                                CommandParameter="{Binding Item.Id}"
                                                Content="Delete permanently"/>

                                    </StackPanel>

                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>
    </Grid>
</UserControl>
