<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Schola.ScholaView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Schola"
             x:DataType="root:ScholaViewModel">
    
    <Border Classes="workspace-toolbar-frame">
        <Grid Classes="workspace-toolbar"
              RowDefinitions="Auto,Auto,Auto"
              ColumnDefinitions="*,Auto">

            <!-- Row 0: Quick actions (left) -->
            <StackPanel Grid.Row="0" Grid.Column="0"
                        Classes="workspace-toolbar-left">
                
                <Button Classes="workspace-toolbar-icon"
                        Width="60"
                        Command="{Binding ShowAddArcPanelCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                        <TextBlock Text="Arc"/>
                    </StackPanel>
                </Button>
                
                <Button Classes="workspace-toolbar-icon"
                        Width="60"
                        Command="{Binding ShowAddUnitPanelCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                        <TextBlock Text="Unit"/>
                    </StackPanel>
                </Button>

                <Button Classes="workspace-toolbar-icon"
                        Command="{Binding RefreshWorkspaceCommand}">
                    <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                </Button>
            </StackPanel>
            
            <!-- Thin separator -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="workspace-toolbar-separator" />
        </Grid>
        
    </Border>
    
</UserControl>
