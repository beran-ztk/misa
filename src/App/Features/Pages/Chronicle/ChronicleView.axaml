<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Chronicle.ChronicleView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Chronicle"
             x:DataType="root:ChronicleViewModel">
    
    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter"/>
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar (2 rows) -->
        <Border Grid.Row="0"
                Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0: Quick actions (left) -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>

                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Thin separator -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="workspace-toolbar-separator" />
            </Grid>
            
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" x:Name="ContentRoot">
            <Border Classes="workspace-content-frame">
                <ItemsControl ItemsSource="{Binding ChronicleEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10">
                                <!-- Day-Header -->
                                <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}" />

                                <!-- Entries-->
                                <ItemsControl ItemsSource="{Binding Entries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                    <!-- Title -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="14" />

                                                    <!-- Time -->
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding OccurredAt, Converter={StaticResource UtcToLocalConverter}, StringFormat='HH:mm'}"
                                                               Opacity="0.7"
                                                               Margin="12,0,0,0" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
