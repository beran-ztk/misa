<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Chronicle.ChronicleView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Chronicle"
             x:DataType="root:ChronicleViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
        <converters:NullToRowHeightConverter x:Key="NullToRowHeightConverter" />
        <converters:ChronicleTypeToChipBackgroundConverter x:Key="ChronicleTypeToChipBackgroundConverter" />
        <converters:ChronicleTypeToChipBorderConverter x:Key="ChronicleTypeToChipBorderConverter" />
        <converters:ChronicleTypeToChipTextConverter x:Key="ChronicleTypeToChipTextConverter" />
        <converters:MetaStateToBackgroundConverter x:Key="MetaStateToBackgroundConverter" />
        <converters:MetaStateToBorderConverter x:Key="MetaStateToBorderConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar (2 rows) -->
        <Border Grid.Row="0"
                Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0: Quick actions (left) -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>

                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Thin separator -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="workspace-toolbar-separator" />
            </Grid>

        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Classes="chronicle-outer-body">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <ItemsControl ItemsSource="{Binding ChronicleEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Day header -->
                                <Border Classes="chronicle-daily-header">
                                    <TextBlock Text="{Binding Date, StringFormat='dd.MM'}" />
                                </Border>

                                <!-- Entries -->
                                <ListBox ItemsSource="{Binding Entries}"
                                         SelectionMode="Single"
                                         SelectionChanged="EntriesList_OnSelectionChanged"
                                         Background="Transparent">

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="chronicle-listbox-items-body">
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="8">
                                                    
                                                    <Border Grid.Column="0"
                                                            Classes="chronicle-type-chip"
                                                            Background="{Binding Type, 
                                                                Converter={StaticResource ChronicleTypeToChipBackgroundConverter}}"
                                                            BorderBrush="{Binding Type, 
                                                                Converter={StaticResource ChronicleTypeToChipBorderConverter}}">
                                                        
                                                        <TextBlock Classes="chronicle-type-chip-text"
                                                                   Text="{Binding Type, 
                                                                    Converter={StaticResource ChronicleTypeToChipTextConverter}}"/>
                                                    </Border>
                                                    
                                                    <!-- Content -->
                                                    <StackPanel Grid.Column="1" Spacing="6">

                                                        <!-- Title -->
                                                        <TextBlock Text="{Binding Title}"
                                                                   Classes="chronicle-listbox-title" />

                                                        <!-- Meta Row -->
                                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                                    IsVisible="{Binding MetaText, Converter={StaticResource NullToBoolConverter}}">

                                                            <!-- optional State Chip -->
                                                            <Border Classes="chronicle-meta-chip"
                                                                    IsVisible="{Binding MetaState, Converter={StaticResource NullToBoolConverter}}"
                                                                    Background="{Binding MetaState, Converter={StaticResource MetaStateToBackgroundConverter}}"
                                                                    BorderBrush="{Binding MetaState, Converter={StaticResource MetaStateToBorderConverter}}">
                                                                <TextBlock Classes="chronicle-meta-chip-text"
                                                                           Text="{Binding MetaState}"/>
                                                            </Border>

                                                            <!-- Meta Text -->
                                                            <TextBlock Classes="chronicle-listbox-meta"
                                                                       Text="{Binding MetaText}" />
                                                        </StackPanel>

                                                        <!-- Description -->
                                                        <TextBlock Classes="chronicle-listbox-description"
                                                                   Text="{Binding Description}"
                                                                   IsVisible="{Binding Description, Converter={StaticResource NullToBoolConverter}}" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding At, Converter={StaticResource UtcToLocalConverter}, StringFormat='HH:mm'}"
                                                               Classes="chronicle-listbox-time" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>