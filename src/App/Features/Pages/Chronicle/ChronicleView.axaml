<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:ic="using:Avalonia.Xaml.Interactivity"
             xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Chronicle.ChronicleView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Chronicle"
             x:DataType="root:ChronicleViewModel">
    
    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter"/>    
        <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar (2 rows) -->
        <Border Grid.Row="0"
                Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0: Quick actions (left) -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>

                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Thin separator -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Classes="workspace-toolbar-separator" />
            </Grid>
            
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" x:Name="ContentRoot">
            <Border Padding="14"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#2A2A2A"
                    Background="#141414">

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <ItemsControl ItemsSource="{Binding ChronicleEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18" Spacing="10">

                                    <!-- Day header -->
                                    <Border Background="#1B1B1B"
                                            CornerRadius="8"
                                            Padding="10,6"
                                            BorderThickness="1"
                                            BorderBrush="#2A2A2A">
                                        <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Opacity="0.9" />
                                    </Border>

                                    <!-- Entries -->
                                    <ListBox ItemsSource="{Binding Entries}"
                                             SelectionMode="Single"
                                             Background="Transparent"
                                             SelectionChanged="EntriesList_OnSelectionChanged"
                                             BorderThickness="0">
                                        
                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>

                                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter Border">
                                                <Setter Property="BorderBrush" Value="#3A82F7"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Style>
                                        </ListBox.Styles>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10"
                                                        Padding="12,10"
                                                        Margin="0,0,0,8"
                                                        Background="#181818"
                                                        BorderThickness="1"
                                                        BorderBrush="#2A2A2A">

                                                    <Grid ColumnDefinitions="*,Auto"
                                                          RowDefinitions="Auto,Auto"
                                                          RowSpacing="6">

                                                        <!-- Title -->
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="{Binding Title}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold" />

                                                        <!-- Time -->
                                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                                   Text="{Binding At, Converter={StaticResource UtcToLocalConverter}, StringFormat='HH:mm'}"
                                                                   Opacity="0.75"
                                                                   Margin="12,0,0,0"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />

                                                        <!-- Description -->
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding Description}"
                                                                   Opacity="0.75"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="2"
                                                                   IsVisible="{Binding Description, Converter={StaticResource NullToBoolConverter}}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </ScrollViewer>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>
