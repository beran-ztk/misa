<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Chronicle.ChronicleView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Chronicle"
             x:DataType="root:ChronicleViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter                    x:Key="UtcToLocalConverter" />
        <converters:NullToBoolConverter                    x:Key="NullToBoolConverter" />
        <converters:ChronicleTypeToChipBackgroundConverter x:Key="TypeToBackground" />
        <converters:ChronicleTypeToChipBorderConverter     x:Key="TypeToBorder" />
        <converters:ChronicleTypeToChipTextConverter       x:Key="TypeToText" />
        <converters:MetaStateToBackgroundConverter         x:Key="MetaToBackground" />
        <converters:MetaStateToBorderConverter             x:Key="MetaToBorder" />
        <converters:ChronicleDateHeaderConverter           x:Key="DateHeader" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0CFFFFFF"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto">

                <!-- Row 0 left: action buttons -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
                    </Button>
                    <Button Classes="workspace-toolbar-icon"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                    </Button>
                </StackPanel>

                <!-- Row 0 right: search — Column 1 sized only by this -->
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Classes="workspace-toolbar-right">
                    <TextBox Classes="workspace-toolbar-search"
                             Watermark="Search title…"
                             Text="{Binding SearchText, Mode=TwoWay}" />
                </StackPanel>

                <!-- Row 1: spans full width — chips left, date range right -->
                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                      ColumnDefinitions="*,Auto">

                    <!-- Type filter chips -->
                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding TypeFilters}"
                                  VerticalAlignment="Center"
                                  Margin="0,5,0,5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding ToggleCommand}"
                                        Classes="chronicle-filter-chip"
                                        Classes.selected="{Binding IsSelected}">
                                    <TextBlock Text="{Binding Label}"
                                               Classes="chronicle-type-chip-text" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Date range — vertical, right-aligned -->
                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,Auto"
                          ColumnDefinitions="40,Auto"
                          RowSpacing="4"
                          Margin="12,5,0,5">

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="From"
                                   FontSize="10"
                                   Opacity="0.55"
                                   VerticalAlignment="Center"/>

                        <DatePicker Grid.Row="0"
                                    Grid.Column="1"
                                    SelectedDate="{Binding FilterFrom, Mode=TwoWay}"
                                    Classes="chronicle-date-filter"/>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="To"
                                   FontSize="10"
                                   Opacity="0.55"
                                   VerticalAlignment="Center"/>

                        <DatePicker Grid.Row="1"
                                    Grid.Column="1"
                                    SelectedDate="{Binding FilterTo, Mode=TwoWay}"
                                    Classes="chronicle-date-filter"/>

                    </Grid>

                </Grid>

                <!-- Row 2: separator -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Classes="workspace-toolbar-separator" />
            </Grid>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1" Classes="chronicle-outer-body">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>

                                <!-- Day header -->
                                <Border Classes="chronicle-daily-header"
                                        Classes.chronicle-upcoming="{Binding IsUpcoming}"
                                        Classes.chronicle-today="{Binding IsToday}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Date, Converter={StaticResource DateHeader}}" />
                                        <Border Grid.Column="1"
                                                IsVisible="{Binding IsUpcoming}"
                                                Classes="chronicle-upcoming-badge">
                                            <TextBlock Text="upcoming"
                                                       Classes="chronicle-upcoming-badge-text" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Entry rows -->
                                <ListBox ItemsSource="{Binding Entries}"
                                         SelectionMode="Single"
                                         SelectionChanged="EntriesList_OnSelectionChanged"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="chronicle-row">
                                                <StackPanel Spacing="3">

                                                    <!-- Main line: chip + title + time -->
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          ColumnSpacing="8">

                                                        <Border Grid.Column="0"
                                                                Classes="chronicle-type-chip"
                                                                Background="{Binding Type, Converter={StaticResource TypeToBackground}}"
                                                                BorderBrush="{Binding Type, Converter={StaticResource TypeToBorder}}">
                                                            <TextBlock Classes="chronicle-type-chip-text"
                                                                       Text="{Binding Type, Converter={StaticResource TypeToText}}" />
                                                        </Border>

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Title}"
                                                                   Classes="chronicle-row-title"
                                                                   VerticalAlignment="Center" />

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding At, Converter={StaticResource UtcToLocalConverter}, StringFormat='HH:mm'}"
                                                                   Classes="chronicle-row-time"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>

                                                    <!-- Sub-line: meta chip + meta text -->
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6"
                                                                Margin="0,0,0,0"
                                                                IsVisible="{Binding MetaText, Converter={StaticResource NullToBoolConverter}}">
                                                        <Border Classes="chronicle-meta-chip"
                                                                IsVisible="{Binding MetaState, Converter={StaticResource NullToBoolConverter}}"
                                                                Background="{Binding MetaState, Converter={StaticResource MetaToBackground}}"
                                                                BorderBrush="{Binding MetaState, Converter={StaticResource MetaToBorder}}">
                                                            <TextBlock Classes="chronicle-meta-chip-text"
                                                                       Text="{Binding MetaState}" />
                                                        </Border>
                                                        <TextBlock Classes="chronicle-row-meta"
                                                                   Text="{Binding MetaText}" />
                                                    </StackPanel>

                                                    <!-- Description (journal content, session summary) -->
                                                    <TextBlock Classes="chronicle-row-description"
                                                               Text="{Binding Description}"
                                                               IsVisible="{Binding Description, Converter={StaticResource NullToBoolConverter}}" />

                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
