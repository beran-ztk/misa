<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Journal.CreateJournalView"
             xmlns:journal="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Journal"
             x:DataType="journal:CreateJournalViewModel">

    <StackPanel Spacing="28">

        <!-- ── Basic ─────────────────────────────────────────────────── -->
        <StackPanel>
            <TextBlock Text="Basic" Classes="form-section-header"/>
            <StackPanel Spacing="16">

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Add a title" Classes="addpanel-text"/>
                    <TextBox Classes="addpanel-oneliner"
                             Watermark="Title…"
                             Text="{Binding JournalTitle, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Add a description" Classes="addpanel-text"/>
                    <TextBox Classes="addpanel-multiline"
                             Watermark="Description…"
                             Text="{Binding Description, Mode=TwoWay}" />
                </StackPanel>

            </StackPanel>
        </StackPanel>

        <!-- ── When ──────────────────────────────────────────────────── -->
        <StackPanel>
            <TextBlock Text="When" Classes="form-section-header"/>
            <StackPanel Spacing="16">

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Occurred at" Classes="addpanel-text"/>
                    <StackPanel Spacing="8">
                        <DatePicker Classes="addpanel-date"
                                    SelectedDate="{Binding OccurredAtDate, Mode=TwoWay}" />
                        <TimePicker Classes="addpanel-time"
                                    SelectedTime="{Binding OccurredAtTime, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Until (optional)" Classes="addpanel-text"/>
                    <StackPanel Spacing="8">
                        <DatePicker Classes="addpanel-date"
                                    SelectedDate="{Binding UntilAtDate, Mode=TwoWay}" />
                        <TimePicker Classes="addpanel-time"
                                    SelectedTime="{Binding UntilAtTime, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </StackPanel>

    </StackPanel>

</UserControl>
