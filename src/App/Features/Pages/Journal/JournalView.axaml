<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Journal.JournalView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Journal"
             x:DataType="root:JournalViewModel">
    
    <StackPanel Classes="workspace-toolbar-left">
        <Button Classes="workspace-toolbar-icon"
                Command="{Binding ShowAddPanelCommand}">
            <Image Source="{SvgImage /Assets/Icons/Common/plus.svg}" />
        </Button>
        <Button Classes="workspace-toolbar-icon"
                Command="{Binding RefreshWorkspaceCommand}">
            <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
        </Button>
    </StackPanel>
    
</UserControl>
