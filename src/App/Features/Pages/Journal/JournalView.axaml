<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Journal.JournalView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Journal"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             x:DataType="root:JournalViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- ── Month navigation arrow buttons ─────────────────────────── -->
        <Style Selector="Button.journal-nav-btn">
            <Setter Property="Width"            Value="26"/>
            <Setter Property="Height"           Value="26"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#0EFFFFFF"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Style>
        </Style>

        <!-- ── Calendar weekday header labels ────────────────────────── -->
        <Style Selector="TextBlock.cal-weekday">
            <Setter Property="FontSize"         Value="9"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="TextAlignment"    Value="Center"/>
        </Style>

        <!-- ── Calendar day cell button ──────────────────────────────── -->
        <Style Selector="Button.cal-day">
            <Setter Property="Width"            Value="22"/>
            <Setter Property="Height"           Value="22"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalAlignment"        Value="Center"/>
            <Setter Property="VerticalAlignment"          Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#0EFFFFFF"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Style>
        </Style>

        <Style Selector="Button.cal-day.cal-today">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.cal-day.cal-selected /template/ ContentPresenter">
            <Setter Property="Background"   Value="{StaticResource BrushAccent}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.cal-day.cal-selected">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.cal-day.cal-selected.cal-today">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ── Entry row ─────────────────────────────────────────────── -->
        <Style Selector="Border.journal-entry-card">
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="0,10,0,12"/>
            <Setter Property="Margin"          Value="0"/>
        </Style>

        <!-- ── Entry row action buttons (Edit / Delete) ──────────────── -->
        <Style Selector="Button.journal-entry-action">
            <Setter Property="Padding"         Value="5,2"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="3"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background"   Value="#0EFFFFFF"/>
            </Style>
        </Style>

        <!-- ── Inline composer content TextBox ───────────────────────── -->
        <!--   Suppress all theme backgrounds/borders so the TextBox sits  -->
        <!--   flush on the surface without a visible box.                 -->
        <Style Selector="TextBox.composer-content">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeMedium}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource BrushAccent}"/>
            <Setter Property="AcceptsReturn"   Value="True"/>
            <Setter Property="TextWrapping"    Value="Wrap"/>
            <Setter Property="MinHeight"       Value="60"/>
        </Style>
        <!-- Flatten all template borders for every interaction state -->
        <Style Selector="TextBox.composer-content /template/ Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.composer-content:pointerover /template/ Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.composer-content:focus /template/ Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.composer-content:focus:pointerover /template/ Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
        </Style>

        <!-- ── Composer action buttons ────────────────────────────────── -->
        <Style Selector="Button.composer-action-save">
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="Background"      Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="4"/>
            </Style>
        </Style>

        <Style Selector="Button.composer-action-cancel">
            <Setter Property="Padding"         Value="12,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="4"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background"   Value="#0EFFFFFF"/>
            </Style>
        </Style>

        <!-- ── Composer time picker ───────────────────────────────────── -->
        <Style Selector="TimePicker.composer-time">
            <Setter Property="MinWidth"        Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        </Style>

        <!-- ── Entry card in edit mode ─────────────────────────────── -->
        <Style Selector="Border.journal-entry-card.editing">
            <Setter Property="Background" Value="#08FFFFFF"/>
            <Setter Property="Padding"    Value="8,10,8,12"/>
        </Style>

        <!-- ── Inline edit TextBox (more compact than top composer) ── -->
        <Style Selector="TextBox.entry-edit-content">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSizeMedium}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource BrushAccent}"/>
            <Setter Property="AcceptsReturn"   Value="True"/>
            <Setter Property="TextWrapping"    Value="Wrap"/>
            <Setter Property="MinHeight"       Value="32"/>
        </Style>
        <Style Selector="TextBox.entry-edit-content /template/ Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.entry-edit-content:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.entry-edit-content:focus /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.entry-edit-content:focus:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════════════════════════════
             TOOLBAR — refresh  ·  month navigation
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar">
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Classes="journal-nav-btn"
                            Command="{Binding PreviousMonthCommand}"
                            Content="←"/>
                    <TextBlock Text="{Binding MonthLabel}"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}"
                               VerticalAlignment="Center"
                               MinWidth="120"
                               TextAlignment="Center"/>
                    <Button Classes="journal-nav-btn"
                            Command="{Binding NextMonthCommand}"
                            Content="→"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             CONTENT — calendar (left)  |  entry view (right)
        ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="172,*">

            <!-- ── Left panel: month calendar grid ──────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="8,10,8,8" Spacing="4">

                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <TextBlock Grid.Column="0" Classes="cal-weekday" Text="M"/>
                        <TextBlock Grid.Column="1" Classes="cal-weekday" Text="T"/>
                        <TextBlock Grid.Column="2" Classes="cal-weekday" Text="W"/>
                        <TextBlock Grid.Column="3" Classes="cal-weekday" Text="T"/>
                        <TextBlock Grid.Column="4" Classes="cal-weekday" Text="F"/>
                        <TextBlock Grid.Column="5" Classes="cal-weekday" Text="S"/>
                        <TextBlock Grid.Column="6" Classes="cal-weekday" Text="S"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding CalendarCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="root:JournalCalendarCell">
                                <Panel Width="22" Height="26">
                                    <Button Classes="cal-day"
                                            Classes.cal-today="{Binding DayItem.IsToday}"
                                            Classes.cal-selected="{Binding IsSelected}"
                                            IsVisible="{Binding !IsEmpty}"
                                            Tag="{Binding DayItem}"
                                            Click="OnDayClicked"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0">
                                        <Panel>
                                            <TextBlock Text="{Binding DayItem.Day}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="3" Height="3"
                                                     Fill="{StaticResource BrushAccent}"
                                                     IsVisible="{Binding DayItem.HasEntries}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Bottom"
                                                     Margin="0,0,0,1"/>
                                        </Panel>
                                    </Button>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

            <!-- ── Right panel: day header + composer + entries ──────── -->
            <DockPanel Grid.Column="1">

                <!-- Day header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,10"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding SelectedDayLabel}"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12,16,16">

                        <!-- ── Always-visible inline composer ────────── -->
                        <StackPanel Margin="0,0,0,0">

                            <!-- Content input — sits flush on the surface -->
                            <TextBox Classes="composer-content"
                                     Watermark="Write your entry…"
                                     KeyUp="InputElement_OnKeyUp"
                                     Text="{Binding ComposerContent, Mode=TwoWay}"/>

                            <!-- Thin rule separating content from controls -->
                            <Border Height="1"
                                    Background="{StaticResource BrushBorder}"
                                    Margin="0,8,0,8"/>

                            <!-- Footer: time (left) · Cancel + Save (right) -->
                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="At"
                                               FontSize="10"
                                               Foreground="{StaticResource BrushTextFaded}"
                                               VerticalAlignment="Center"/>
                                    <TimePicker Classes="composer-time"
                                                SelectedTime="{Binding ComposerTime, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <Button Classes="composer-action-cancel"
                                            Content="Cancel"
                                            Command="{Binding ResetComposerCommand}"/>
                                    <Button Classes="composer-action-save"
                                            Content="Save"
                                            Command="{Binding SubmitComposerCommand}"/>
                                </StackPanel>

                            </Grid>

                        </StackPanel>

                        <!-- Divider between composer and entries -->
                        <Border Height="1"
                                Background="{StaticResource BrushBorder}"
                                Margin="0,16,0,12"/>

                        <!-- Empty state -->
                        <TextBlock Text="No entries for this day."
                                   IsVisible="{Binding !HasEntries}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextFaded}"
                                   Margin="0,0,0,4"/>

                        <!-- Entry rows -->
                        <ItemsControl ItemsSource="{Binding SelectedDayEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="root:JournalEntryRow">
                                    <Border Classes="journal-entry-card"
                                            Classes.editing="{Binding IsEditing}">

                                        <StackPanel>
                                            <!-- ── Read view ───────────────────────────────── -->
                                            <Grid IsVisible="{Binding !IsEditing}"
                                                  ColumnDefinitions="*,Auto">

                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="{Binding Entry.At,
                                                                   Converter={StaticResource UtcToLocalConverter},
                                                                   StringFormat='HH:mm'}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource BrushTextFaded}"/>
                                                    <TextBlock Text="{Binding Entry.Description}"
                                                               IsVisible="{Binding Entry.Description,
                                                                   Converter={StaticResource NullToBoolConverter}}"
                                                               FontSize="{StaticResource FontSizeMedium}"
                                                               Foreground="{StaticResource BrushTextPrimary}"
                                                               TextWrapping="Wrap"
                                                               LineHeight="20"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="2"
                                                            VerticalAlignment="Top"
                                                            Margin="8,0,0,0">
                                                    <Button Classes="journal-entry-action"
                                                            Content="Edit"
                                                            Command="{Binding BeginEditCommand}"/>
                                                    <Button Classes="journal-entry-action"
                                                            Content="Delete"
                                                            Command="{Binding DeleteCommand}"/>
                                                </StackPanel>

                                            </Grid>

                                            <!-- ── Edit view ───────────────────────────────── -->
                                            <StackPanel IsVisible="{Binding IsEditing}" Spacing="0">

                                                <TextBox Classes="entry-edit-content"
                                                         Text="{Binding EditContent, Mode=TwoWay}"/>

                                                <Border Height="1"
                                                        Background="{StaticResource BrushBorder}"
                                                        Margin="0,6,0,6"/>

                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <StackPanel Grid.Column="0"
                                                                Orientation="Horizontal"
                                                                Spacing="6"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="At"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource BrushTextFaded}"
                                                                   VerticalAlignment="Center"/>
                                                        <TimePicker Classes="composer-time"
                                                                    SelectedTime="{Binding EditTime, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Spacing="6">
                                                        <Button Classes="composer-action-cancel"
                                                                Content="Cancel"
                                                                Command="{Binding CancelEditCommand}"/>
                                                        <Button Classes="composer-action-save"
                                                                Content="Save"
                                                                Command="{Binding SaveEditCommand}"/>
                                                    </StackPanel>
                                                </Grid>

                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>

        </Grid>

    </Grid>

</UserControl>
