<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Misa.Ui.Avalonia.Features.Pages.Journal.JournalView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Pages.Journal"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             x:DataType="root:JournalViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter"/>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>

        <!-- ── Month navigation arrow buttons ─────────────────────────── -->
        <Style Selector="Button.journal-nav-btn">
            <Setter Property="Width"            Value="26"/>
            <Setter Property="Height"           Value="26"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#0EFFFFFF"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Style>
        </Style>

        <!-- ── Calendar weekday header labels ────────────────────────── -->
        <Style Selector="TextBlock.cal-weekday">
            <Setter Property="FontSize"         Value="9"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="TextAlignment"    Value="Center"/>
        </Style>

        <!-- ── Calendar day cell button ──────────────────────────────── -->
        <Style Selector="Button.cal-day">
            <Setter Property="Width"            Value="22"/>
            <Setter Property="Height"           Value="22"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="HorizontalAlignment"        Value="Center"/>
            <Setter Property="VerticalAlignment"          Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius"    Value="4"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#0EFFFFFF"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#18FFFFFF"/>
            </Style>
        </Style>

        <!-- Today: accent-coloured foreground, subtle ring -->
        <Style Selector="Button.cal-day.cal-today">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Selected: solid accent background, primary text -->
        <Style Selector="Button.cal-day.cal-selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.cal-day.cal-selected">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- Selected + today: keep accent background, slightly bolder -->
        <Style Selector="Button.cal-day.cal-selected.cal-today">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ── Entry card ─────────────────────────────────────────────── -->
        <Style Selector="Border.journal-entry-card">
            <Setter Property="Background"      Value="{StaticResource BrushPrimaryBackground}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="Padding"         Value="12,10,12,12"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- ══════════════════════════════════════════════════════════════
             TOOLBAR — refresh  ·  month navigation  ·  add entry
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Classes="workspace-toolbar-frame">
            <Grid Classes="workspace-toolbar"
                  ColumnDefinitions="Auto,*,Auto">

                <!-- Left: refresh -->
                <StackPanel Grid.Column="0"
                            Classes="workspace-toolbar-left">
                    <Button Classes="workspace-toolbar-icon"
                            ToolTip.Tip="Refresh"
                            Command="{Binding RefreshWorkspaceCommand}">
                        <Image Width="14" Height="14"
                               Source="{SvgImage /Assets/Icons/Common/refresh.svg}"/>
                    </Button>
                </StackPanel>

                <!-- Center: month navigation -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Classes="journal-nav-btn"
                            Command="{Binding PreviousMonthCommand}"
                            Content="←"/>
                    <TextBlock Text="{Binding MonthLabel}"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}"
                               VerticalAlignment="Center"
                               MinWidth="120"
                               TextAlignment="Center"/>
                    <Button Classes="journal-nav-btn"
                            Command="{Binding NextMonthCommand}"
                            Content="→"/>
                </StackPanel>

                <!-- Right: add entry -->
                <StackPanel Grid.Column="2"
                            Classes="workspace-toolbar-right">
                    <Button Classes="workspace-toolbar-icon"
                            ToolTip.Tip="New journal entry"
                            Command="{Binding ShowAddPanelCommand}">
                        <Image Width="14" Height="14"
                               Source="{SvgImage /Assets/Icons/Common/plus.svg}"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             CONTENT — calendar (left)  |  entry view (right)
        ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="172,*">

            <!-- ── Left panel: month calendar grid ──────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel Margin="8,10,8,8" Spacing="4">

                    <!-- Weekday headers: Mon → Sun -->
                    <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                        <TextBlock Grid.Column="0" Classes="cal-weekday" Text="M"/>
                        <TextBlock Grid.Column="1" Classes="cal-weekday" Text="T"/>
                        <TextBlock Grid.Column="2" Classes="cal-weekday" Text="W"/>
                        <TextBlock Grid.Column="3" Classes="cal-weekday" Text="T"/>
                        <TextBlock Grid.Column="4" Classes="cal-weekday" Text="F"/>
                        <TextBlock Grid.Column="5" Classes="cal-weekday" Text="S"/>
                        <TextBlock Grid.Column="6" Classes="cal-weekday" Text="S"/>
                    </Grid>

                    <!-- Day cells -->
                    <ItemsControl ItemsSource="{Binding CalendarCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="root:JournalCalendarCell">
                                <!-- Fixed-size slot; empty cells are transparent spacers -->
                                <Panel Width="22" Height="26">

                                    <!-- Day button (hidden for empty/padding cells) -->
                                    <Button Classes="cal-day"
                                            Classes.cal-today="{Binding DayItem.IsToday}"
                                            Classes.cal-selected="{Binding IsSelected}"
                                            IsVisible="{Binding !IsEmpty}"
                                            Tag="{Binding DayItem}"
                                            Click="OnDayClicked"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0">
                                        <Panel>
                                            <TextBlock Text="{Binding DayItem.Day}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- Entry dot badge -->
                                            <Ellipse Width="3" Height="3"
                                                     Fill="{StaticResource BrushAccent}"
                                                     IsVisible="{Binding DayItem.HasEntries}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Bottom"
                                                     Margin="0,0,0,1"/>
                                        </Panel>
                                    </Button>

                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

            <!-- ── Right panel: selected day entries ───────────────── -->
            <DockPanel Grid.Column="1">

                <!-- Selected day header -->
                <Border DockPanel.Dock="Top"
                        Padding="16,10"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding SelectedDayLabel}"
                               FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}"/>
                </Border>

                <!-- Entries scroll area -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12,16,16">

                        <!-- Empty state -->
                        <TextBlock Text="No entries for this day."
                                   IsVisible="{Binding !HasEntries}"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextFaded}"
                                   Margin="0,4,0,0"/>

                        <!-- Entry cards -->
                        <ItemsControl ItemsSource="{Binding SelectedDayEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="journal-entry-card">
                                        <StackPanel Spacing="0">

                                            <!-- Time -->
                                            <TextBlock Text="{Binding At,
                                                           Converter={StaticResource UtcToLocalConverter},
                                                           StringFormat='HH:mm'}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrushTextFaded}"
                                                       Margin="0,0,0,4"/>

                                            <!-- Title -->
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="{StaticResource FontSizeMedium}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       TextWrapping="Wrap"/>

                                            <!-- Description (only when present) -->
                                            <TextBlock Text="{Binding Description}"
                                                       IsVisible="{Binding Description,
                                                           Converter={StaticResource NullToBoolConverter}}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>

        </Grid>

    </Grid>

</UserControl>
