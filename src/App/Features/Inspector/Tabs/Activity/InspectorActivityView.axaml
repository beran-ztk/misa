<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:sessions="clr-namespace:Misa.Contract.Items.Components.Activity.Sessions;assembly=Contract"
             xmlns:audits="clr-namespace:Misa.Contract.Items.Components.Audits;assembly=Contract"
             xmlns:activity="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Activity"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Activity.InspectorActivityView"
             x:DataType="activity:InspectorActivityViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.session-card">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style Selector="Border.state-badge">
            <Setter Property="Padding"     Value="7,2" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="Background"  Value="#0EFFFFFF" />
        </Style>

        <Style Selector="TextBlock.state-badge-text">
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Opacity"      Value="0.75" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource BrushPrimaryBackground}"
            Margin="0,16,0,0"
            Padding="12">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="24">

                <!-- Sessions section — only shown for real activity items (Task) -->
                <StackPanel Spacing="8"
                            IsVisible="{Binding ShowSessions}">
                    <Border BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="4,0,4,8">
                        <TextBlock Text="Sessions"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Opacity="0.85" />
                    </Border>

                    <TextBlock Text="No sessions yet."
                               Opacity="0.45"
                               FontSize="13"
                               Margin="4,0"
                               IsVisible="{Binding !HasSessions}" />

                    <ItemsControl ItemsSource="{Binding Sessions}"
                                  IsVisible="{Binding HasSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sessions:SessionDto">
                                <Border Classes="session-card" Margin="0,0,0,8">
                                    <StackPanel Spacing="10">

                                        <!-- Header: state badge + date -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0" Classes="state-badge">
                                                <TextBlock Classes="state-badge-text"
                                                           Text="{Binding State}" />
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CreatedAtUtc, Converter={StaticResource UtcToLocalConverter}, StringFormat='dd.MM.yyyy HH:mm'}"
                                                       Classes="meta"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- Objective -->
                                        <StackPanel Spacing="2"
                                                    IsVisible="{Binding Objective, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="Objective" Classes="label" />
                                            <TextBlock Text="{Binding Objective}"
                                                       FontSize="13"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Summary -->
                                        <StackPanel Spacing="2"
                                                    IsVisible="{Binding Summary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="Summary" Classes="label" />
                                            <TextBlock Text="{Binding Summary}"
                                                       FontSize="12"
                                                       Opacity="0.80"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        
                                        <!-- Duration + segments + quality -->
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Duration" Classes="label" />
                                                <TextBlock Text="{Binding DurationDisplay}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Segments" Classes="label" />
                                                <TextBlock Text="{Binding Segments.Count}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Spacing="2"
                                                        IsVisible="{Binding EfficiencyDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <TextBlock Text="Efficiency" Classes="label" />
                                                <TextBlock Text="{Binding EfficiencyDisplay}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Spacing="2"
                                                        IsVisible="{Binding ConcentrationDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <TextBlock Text="Concentration" Classes="label" />
                                                <TextBlock Text="{Binding ConcentrationDisplay}" FontSize="12" />
                                            </StackPanel>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Changes section -->
                <StackPanel Spacing="8">
                    <Border BorderBrush="{StaticResource BrushBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="4,0,4,8">
                        <TextBlock Text="Changes"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Opacity="0.85" />
                    </Border>

                    <TextBlock Text="No recorded changes yet."
                               Opacity="0.45"
                               FontSize="13"
                               Margin="4,0"
                               IsVisible="{Binding !HasChanges}" />

                    <ItemsControl ItemsSource="{Binding Changes}"
                                  IsVisible="{Binding HasChanges}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="audits:AuditChangeDto">
                                <Border Margin="0,0,0,8"
                                        Padding="12,8"
                                        Background="{StaticResource BrushPrimaryBackgroundLight}"
                                        BorderBrush="{StaticResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">

                                        <!-- Change type badge -->
                                        <Border Grid.Column="0"
                                                Classes="state-badge"
                                                VerticalAlignment="Top">
                                            <TextBlock Classes="state-badge-text"
                                                       Text="{Binding ChangeType}" />
                                        </Border>

                                        <!-- Old → New -->
                                        <Grid Grid.Column="1"
                                              ColumnDefinitions="*,Auto,*"
                                              ColumnSpacing="8"
                                              VerticalAlignment="Top">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ValueBefore, TargetNullValue='—'}"
                                                       FontSize="12"
                                                       Opacity="0.60"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="4" />

                                            <TextBlock Grid.Column="1"
                                                       Text="→"
                                                       FontSize="11"
                                                       Opacity="0.40"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,0,0" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ValueAfter, TargetNullValue='—'}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="4" />
                                        </Grid>

                                        <!-- Timestamp -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CreatedAtUtc, Converter={StaticResource UtcToLocalConverter}, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   Classes="meta"
                                                   VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
