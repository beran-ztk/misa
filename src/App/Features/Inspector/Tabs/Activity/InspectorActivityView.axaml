<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:sessions="clr-namespace:Misa.Contract.Items.Components.Activity.Sessions;assembly=Contract"
             xmlns:activity="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Activity"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Activity.InspectorActivityView"
             x:DataType="activity:InspectorActivityViewModel">

    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.session-card">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
        </Style>

        <Style Selector="Border.state-badge">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
            <Setter Property="Background" Value="#0EFFFFFF" />
        </Style>

        <Style Selector="TextBlock.state-badge-text">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="LetterSpacing" Value="0.5" />
        </Style>

        <Style Selector="TextBlock.meta">
            <Setter Property="Opacity" Value="0.50" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource BrushPrimaryBackground}"
            Margin="0,20,0,0"
            Padding="12">

        <Grid RowDefinitions="Auto,*">

            <!-- Section header -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="4,8,4,10"
                    Margin="0,0,0,12">
                <TextBlock Text="Sessions"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Opacity="0.85" />
            </Border>

            <!-- Session list -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="10">

                    <!-- Empty state -->
                    <TextBlock Text="No sessions yet."
                               Opacity="0.45"
                               FontSize="13"
                               Margin="4,4"
                               IsVisible="{Binding !HasSessions}" />

                    <!-- Session cards -->
                    <ItemsControl ItemsSource="{Binding Sessions}"
                                  IsVisible="{Binding HasSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sessions:SessionDto">
                                <Border Classes="session-card" Margin="0,0,0,8">
                                    <StackPanel Spacing="8">

                                        <!-- Header: state badge + date -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Border Grid.Column="0" Classes="state-badge">
                                                <TextBlock Classes="state-badge-text"
                                                           Text="{Binding State}" />
                                            </Border>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CreatedAtUtc, Converter={StaticResource UtcToLocalConverter}, StringFormat='dd.MM.yyyy HH:mm'}"
                                                       Classes="meta"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- Objective -->
                                        <TextBlock Text="{Binding Objective}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding Objective, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                        <!-- Duration + segments row -->
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Duration" Classes="label" />
                                                <TextBlock Text="{Binding DurationDisplay}"
                                                           FontSize="12" />
                                            </StackPanel>

                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Segments" Classes="label" />
                                                <TextBlock Text="{Binding Segments.Count}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Summary (ended sessions) -->
                                        <StackPanel Spacing="2"
                                                    IsVisible="{Binding Summary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="Summary" Classes="label" />
                                            <TextBlock Text="{Binding Summary}"
                                                       FontSize="12"
                                                       Opacity="0.80"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Border>
</UserControl>
