<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.MarkAsDone.MarkItemDoneView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.MarkAsDone"
             x:DataType="root:MarkItemDoneViewModel">

    <StackPanel Spacing="16">

        <StackPanel Classes="addpanel-controls">
            <TextBlock Text="Reason (optional)"
                       Classes="addpanel-text" />
            <TextBox Classes="addpanel-oneliner"
                     Text="{Binding Reason, Mode=TwoWay}"
                     Watermark="Why is this done? (optional)" />
        </StackPanel>

    </StackPanel>

</UserControl>
