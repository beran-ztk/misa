<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Relations.Forms"
             xmlns:dtos="clr-namespace:Misa.Core.Features.Items.Relations;assembly=Application"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Relations.Forms.CreateRelationView"
             x:DataType="vm:CreateRelationViewModel">

    <UserControl.Styles>
        <!-- Item row in list — full-row selection feel -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Styles>

    <!--
        Three-row grid — 16 px row gap mirrors the StackPanel.addpanel-body spacing.

        Ordering rationale:
          Row 0  Search + workflow filter  (always visible, top anchor)
          Row 1  Relation type             (always visible; placed BEFORE the list so
                                            it is never pushed out of view by list growth)
          Row 2  Item picker list          (last; any overflow clips at the bottom,
                                            not at the controls that matter)
    -->
    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">

        <!-- Row 0: Search + workflow filter -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8">

            <TextBox Grid.Column="0"
                     Watermark="Search by title…"
                     Text="{Binding SearchText, Mode=TwoWay}"/>

            <ComboBox Grid.Column="1"
                      Classes="addpanel-combo"
                      MinWidth="120"
                      ItemsSource="{Binding WorkflowOptions}"
                      SelectedItem="{Binding SelectedWorkflowFilter, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WorkflowFilterOption">
                        <TextBlock Text="{Binding Display}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

        </Grid>

        <!-- Row 1: Relation type — anchored above the list so it is always reachable -->
        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Relation type"
                       Classes="addpanel-text"/>
            <ComboBox Classes="addpanel-combo"
                      ItemsSource="{Binding RelationTypes}"
                      SelectedItem="{Binding SelectedRelationType, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Row 2: Item picker — bounded list; its own ScrollViewer handles many items -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding FilteredItems}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 MinHeight="160"
                 MaxHeight="300"
                 BorderThickness="0,1"
                 BorderBrush="{StaticResource BrushBorder}"
                 Background="{StaticResource BrushPrimaryBackground}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="dtos:ItemLookupDto">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Workflow}"
                                   FontSize="11"
                                   Opacity="0.45"
                                   VerticalAlignment="Center"/>

                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>

</UserControl>
