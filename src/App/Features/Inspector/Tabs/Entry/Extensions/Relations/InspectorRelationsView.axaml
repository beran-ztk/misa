<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:relations="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Relations"
             xmlns:dtos="clr-namespace:Misa.Contract.Items.Components.Relations;assembly=Contract"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Relations.InspectorRelationsView"
             x:DataType="relations:InspectorRelationsViewModel">

    <UserControl.Styles>
        <Style Selector="Button.relation-nav-title">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.relation-nav-title:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.relation-nav-title:pointerover TextBlock">
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>
    </UserControl.Styles>

    <Border BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="0,0,0,1"
            Padding="4,8">
        
        <Grid RowDefinitions="Auto,Auto"
              RowSpacing="8">

            <!-- Section header -->
            <Border Grid.Row="0">
                <Grid ColumnDefinitions="*,Auto">

                    <TextBlock Grid.Column="0"
                               Text="Relations"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Opacity="0.65"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Classes="workspace-toolbar-icon"
                            VerticalAlignment="Center"
                            Command="{Binding OpenCreateModalCommand}">
                        <Image Width="14" Height="14"
                               Source="{SvgImage /Assets/Icons/Common/plus.svg}"/>
                    </Button>

                </Grid>
            </Border>
            
            <StackPanel Grid.Row="1">
                <!-- Empty state -->
                <TextBlock Text="No relations."
                           Opacity="0.40"
                           FontSize="12"
                           IsVisible="{Binding !HasRelations}"/>

                <!-- Relations list -->
                <ItemsControl ItemsSource="{Binding RelationRows}"
                              IsVisible="{Binding HasRelations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="relations:RelationRowVm">
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="8">

                                    <!-- Left: chip + readable sentence -->
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">

                                        <Border CornerRadius="3"
                                                Padding="5,1"
                                                BorderThickness="1"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                Background="Transparent"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChipLabel}"
                                                       FontSize="10"
                                                       Opacity="0.45"
                                                       LetterSpacing="0.2"/>
                                        </Border>

                                        <TextBlock Text="{Binding RelationLabel}"
                                                   FontSize="12"
                                                   Opacity="0.50"
                                                   VerticalAlignment="Center"/>

                                    </StackPanel>

                                    <!-- Center: clickable title + inline workflow -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="4"
                                                VerticalAlignment="Center">

                                        <Button Classes="relation-nav-title"
                                                Command="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).NavigateToItemCommand}"
                                                CommandParameter="{Binding OtherItemId}">
                                            <TextBlock Text="{Binding OtherTitle}"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Button>

                                        <TextBlock Text="{Binding OtherWorkflow}"
                                                   FontSize="10"
                                                   Opacity="0.35"
                                                   VerticalAlignment="Center"/>

                                    </StackPanel>

                                    <!-- Right: edit / delete -->
                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Spacing="2"
                                                VerticalAlignment="Center">

                                        <Button Classes="workspace-toolbar-icon"
                                                Command="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).StartEditCommand}"
                                                CommandParameter="{Binding}">
                                            <Image Width="12" Height="12"
                                                   Source="{SvgImage /Assets/Icons/Common/edit.svg}"/>
                                        </Button>

                                        <Button Classes="workspace-toolbar-icon"
                                                Command="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).DeleteRelationCommand}"
                                                CommandParameter="{Binding}">
                                            <Image Width="12" Height="12"
                                                   Source="{SvgImage /Assets/Icons/Common/trash.svg}"/>
                                        </Button>

                                    </StackPanel>

                                </Grid>

                                <!-- ── Inline edit row ── -->
                                <Border IsVisible="{Binding IsEditing}"
                                        Padding="4,8"
                                        Background="{StaticResource BrushPrimaryBackgroundLight}"
                                        CornerRadius="4">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="8"
                                          VerticalAlignment="Center">

                                        <TextBlock Grid.Column="0"
                                                   Text="Type"
                                                   FontSize="11"
                                                   Opacity="0.50"
                                                   VerticalAlignment="Center"/>

                                        <ComboBox Grid.Column="1"
                                                  Classes="addpanel-combo"
                                                  ItemsSource="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).RelationTypes}"
                                                  SelectedItem="{Binding EditingType, Mode=TwoWay}"/>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                            <Button Classes="confirm-cancel-cancel"
                                                    Content="Cancel"
                                                    Command="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).CancelEditCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="confirm-cancel-confirm"
                                                    Content="Save"
                                                    Command="{Binding $parent[ItemsControl].((relations:InspectorRelationsViewModel)DataContext).SubmitEditCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            
        </Grid>
    </Border>
</UserControl>
