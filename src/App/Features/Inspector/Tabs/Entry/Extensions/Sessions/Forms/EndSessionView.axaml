<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Sessions.Forms.EndSessionView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Sessions.Forms"
             x:DataType="root:EndSessionViewModel">

    <StackPanel Spacing="28">

        <!-- ── Quality ───────────────────────────────────────────────── -->
        <StackPanel>
            <TextBlock Text="Quality" Classes="form-section-header"/>
            <StackPanel Spacing="16">

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Efficiency" Classes="addpanel-text"/>
                    <ComboBox Classes="addpanel-combo"
                              ItemsSource="{Binding Efficiencies}"
                              SelectedItem="{Binding SelectedSessionEfficiency}" />
                </StackPanel>

                <StackPanel Classes="addpanel-controls">
                    <TextBlock Text="Concentration" Classes="addpanel-text"/>
                    <ComboBox Classes="addpanel-combo"
                              ItemsSource="{Binding Concentrations}"
                              SelectedItem="{Binding SelectedSessionConcentration}" />
                </StackPanel>

            </StackPanel>
        </StackPanel>

        <!-- ── Reflection ────────────────────────────────────────────── -->
        <StackPanel>
            <TextBlock Text="Reflection" Classes="form-section-header"/>
            <StackPanel Classes="addpanel-controls">
                <TextBlock Text="Summary" Classes="addpanel-text"/>
                <TextBox Classes="addpanel-multiline"
                         Text="{Binding Summary, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="90"
                         Watermark="What happened? Short summary." />
            </StackPanel>
        </StackPanel>

    </StackPanel>

</UserControl>
