<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Sessions.SessionHeaderView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Base"
             x:DataType="root:InspectorEntryViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.session-elapsed-over">
            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
        </Style>

        <Style Selector="Border.session-state-chip">
            <Setter Property="CornerRadius"      Value="4"/>
            <Setter Property="Padding"           Value="6,2"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.session-state-chip TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="LetterSpacing"     Value="0.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.session-state-chip.running">
            <Setter Property="Background"  Value="#1A3D8B4F"/>
            <Setter Property="BorderBrush" Value="#403D8B4F"/>
        </Style>
        <Style Selector="Border.session-state-chip.running TextBlock">
            <Setter Property="Foreground" Value="#65B56A"/>
        </Style>
        <Style Selector="Border.session-state-chip.paused">
            <Setter Property="Background"  Value="#18F0A020"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushWarning}"/>
        </Style>
        <Style Selector="Border.session-state-chip.paused TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushWarning}"/>
        </Style>

        <Style Selector="Button.session-continue-btn">
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Background"      Value="#10FFFFFF"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Cursor"          Value="Hand"/>

            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="4"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#1AFFFFFF"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#28FFFFFF"/>
            </Style>
        </Style>

    </UserControl.Styles>

    <Border Padding="4,12"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BrushBorder}">

        <!--
            2 columns × 2 rows:
              (0,0) state chip + duration   |  (0,1) quick actions
              (1,0–1) objective — ColSpan 2, only when set
        -->
        <Grid ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="12">

            <!-- ── (Row 0, Col 0): state + duration ──────────────────────── -->

            <!-- Empty state -->
            <StackPanel Grid.Row="0" Grid.Column="0"
                        Spacing="2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !HasActiveSession}">

                <TextBlock Text="No session active"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="{StaticResource BrushTextSecondary}"
                           Opacity="0.75"/>

            </StackPanel>

            <!-- Active state: chip left, duration right -->
            <Grid Grid.Row="0" Grid.Column="0"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="10"
                  VerticalAlignment="Center"
                  IsVisible="{Binding HasActiveSession}">

                <Border Grid.Column="0"
                        Classes="session-state-chip"
                        Classes.running="{Binding IsRunning}"
                        Classes.paused="{Binding IsPaused}">
                    <TextBlock Text="{Binding SessionStateLabel}"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <TextBlock Text="{Binding ActiveSessionElapsedDisplay}"
                               Classes.session-elapsed-over="{Binding IsOverPlannedDuration}"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextSecondary}"/>

                    <TextBlock Text="{Binding ActiveSessionPlannedSuffixDisplay}"
                               FontSize="11"
                               Foreground="{StaticResource BrushTextFaded}"
                               Opacity="0.7"/>

                </StackPanel>

            </Grid>

            <!-- ── (Row 0, Col 1): quick actions ─────────────────────────── -->

            <StackPanel Grid.Row="0" Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">

                <Button Classes="workspace-toolbar-icon"
                        ToolTip.Tip="Start session"
                        Command="{Binding ShowStartSessionPanelCommand}"
                        IsVisible="{Binding CanStartSession}">
                    <Image Width="15" Height="15"
                           Source="{SvgImage /Assets/Icons/Inspector/Session/play.svg}"/>
                </Button>

                <Button Classes="workspace-toolbar-icon"
                        ToolTip.Tip="Pause session"
                        Command="{Binding ShowPauseSessionPanelCommand}"
                        IsVisible="{Binding CanPauseSession}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Image Width="11" Height="11"
                               VerticalAlignment="Center"
                               Source="{SvgImage /Assets/Icons/Inspector/Session/pause.svg}"/>
                        <TextBlock Text="Pause" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="session-continue-btn"
                        Command="{Binding ContinueSessionCommand}"
                        IsVisible="{Binding CanContinueSession}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Image Width="11" Height="11"
                               VerticalAlignment="Center"
                               Source="{SvgImage /Assets/Icons/Inspector/Session/play-pause.svg}"/>
                        <TextBlock Text="Continue" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Classes="workspace-toolbar-icon"
                        ToolTip.Tip="End session"
                        Command="{Binding ShowEndSessionPanelCommand}"
                        IsVisible="{Binding CanEndSession}">
                    <Image Width="15" Height="15"
                           Source="{SvgImage /Assets/Icons/Inspector/Session/stop.svg}"/>
                </Button>

            </StackPanel>

            <!-- ── (Row 1, Col 0–1): objective — full width, wraps freely ── -->

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"
                       IsVisible="{Binding HasActiveSessionObjective}">
                <Run Text="Objective: "
                     Foreground="{StaticResource BrushTextFaded}"/>
                <Run Text="{Binding ActiveSessionObjective}"
                     Foreground="{StaticResource BrushTextSecondary}"/>
            </TextBlock>

        </Grid>

    </Border>

</UserControl>
