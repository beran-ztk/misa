<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Base.InspectorEntryView"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Base"
             xmlns:deadline="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Scheduling"
             xmlns:session="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Tabs.Entry.Extensions.Sessions"
             x:DataType="root:InspectorEntryViewModel">

    <UserControl.Resources>
        <converters:NullToStringNoValueIndicator x:Key="NoValueConverter"/>
    </UserControl.Resources>
    
    <Border Background="{StaticResource BrushPrimaryBackground}"
            Margin="0,20,0,0"
            Padding="12">
        <Grid RowDefinitions="50,Auto,Auto,*">

            <!-- Header -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,5"
                    Padding="12,8">

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">

                    <TextBlock Grid.Column="0"
                               Text="{Binding Facade.State.Item.Title}"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Regular" />

                    <StackPanel Grid.Column="1"
                                Spacing="10"
                                Orientation="Horizontal">
                        <!-- Refresh -->
                        <Button Classes="workspace-toolbar-icon"
                                Command="{Binding Facade.ReloadCommand}">
                            <Image Source="{SvgImage /Assets/Icons/Common/refresh.svg}" />
                        </Button>

                        <!-- 3-dots menu -->
                        <Button Classes="workspace-toolbar-icon"
                                VerticalAlignment="Center">
                            <Image Source="{SvgImage /Assets/Icons/Common/dots-three-vertical.svg}" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem>
                                        <MenuItem.Header>
                                            <StackPanel Spacing="8" Orientation="Horizontal">
                                                <Image Width="16" Height="16"
                                                       Source="{SvgImage /Assets/Icons/Common/archive.svg}" />
                                                <TextBlock Text="Archive Item" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <MenuItem>
                                        <MenuItem.Header>
                                            <StackPanel Spacing="8" Orientation="Horizontal">
                                                <Image Width="16" Height="16"
                                                       Source="{SvgImage /Assets/Icons/Common/trash.svg}" />
                                                <TextBlock Text="Delete Item" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Deadline -->
            <deadline:EntryDeadlineView Grid.Row="1"
                                        IsVisible="{Binding Facade.State.CanHaveActivity}" />

            <!-- Session -->
            <session:SessionHeaderView Grid.Row="2"
                                       IsVisible="{Binding Facade.State.CanHaveActivity}" />

            <!-- Body -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <Border Padding="20">
                    <StackPanel Spacing="14">

                        <!-- Header + Edit -->
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="12">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding OverviewTitle}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Row="0" Grid.Column="1"
                                    Classes="workspace-toolbar-icon"
                                    VerticalAlignment="Center"
                                    Command="{Binding ShowEditItemFormCommand}">
                                <Image Source="{SvgImage /Assets/Icons/Common/edit.svg}" />
                            </Button>

                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource BrushBorder}" />
                        </Grid>

                        <!-- View/Edit -->
                        <StackPanel Classes="addpanel-body">

                            <!-- Title -->
                            <StackPanel Classes="addpanel-controls">
                                <TextBlock Text="Title"
                                           Classes="addpanel-text" />

                                <TextBlock Text="{Binding Facade.State.Item.Title}"
                                           IsVisible="{Binding !Facade.State.IsEditItemFormOpen}" />

                                <TextBox Classes="addpanel-oneliner"
                                         Watermark="Title…"
                                         Text="{Binding EditTitle, Mode=TwoWay}"
                                         IsVisible="{Binding Facade.State.IsEditItemFormOpen}" />
                            </StackPanel>

                            <!-- Description -->
                            <StackPanel Classes="addpanel-controls">
                                <TextBlock Text="Description"
                                           Classes="addpanel-text" />

                                <TextBlock Text="{Binding Facade.State.Item.Description, Converter={StaticResource NoValueConverter}}"
                                           IsVisible="{Binding !Facade.State.IsEditItemFormOpen}" />

                                <TextBox Classes="addpanel-oneliner"
                                         Watermark="Description…"
                                         Text="{Binding EditDescription, Mode=TwoWay}"
                                         IsVisible="{Binding Facade.State.IsEditItemFormOpen}" />
                            </StackPanel>

                            <!-- Created At -->
                            <StackPanel Classes="addpanel-controls">
                                <TextBlock Text="Created"
                                           Classes="addpanel-text" />

                                <TextBlock Text="{Binding Facade.State.Item.CreatedAt}" />
                            </StackPanel>

                            <!-- Modified At -->
                            <StackPanel Classes="addpanel-controls">
                                <TextBlock Text="Modified"
                                           Classes="addpanel-text" />

                                <TextBlock Text="{Binding Facade.State.Item.ModifiedAt, Converter={StaticResource NoValueConverter}}" />
                            </StackPanel>

                            <!-- Category (Task only) -->
                            <StackPanel Classes="addpanel-controls">
                                <TextBlock Text="Category"
                                           Classes="addpanel-text" />

                                <TextBlock Text="{Binding Facade.State.Item.TaskExtension.Category, Converter={StaticResource NoValueConverter}}"
                                           IsVisible="{Binding !Facade.State.IsEditItemFormOpen}" />

                                <ComboBox Classes="addpanel-combo"
                                          ItemsSource="{Binding Facade.State.Categories}"
                                          SelectedItem="{Binding Facade.State.Item.TaskExtension.Category, Mode=TwoWay}"
                                          IsVisible="{Binding Facade.State.IsEditItemFormOpen}" />
                            </StackPanel>

                        </StackPanel>

                    </StackPanel>
                </Border>
            </ScrollViewer>

        </Grid>
    </Border>

</UserControl>