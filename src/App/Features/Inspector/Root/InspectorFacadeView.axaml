<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Root.InspectorFacadeView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Root"
             x:DataType="root:InspectorFacadeViewModel">

    <UserControl.Styles>

        <Style Selector="Button.tab-option">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.tab-option /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
        </Style>
        <Style Selector="Button.tab-option:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
        <Style Selector="Button.tab-option.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackground}"/>
        </Style>

        <Style Selector="Button.tab-option TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeAverage}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
        </Style>
        <Style Selector="Button.tab-option.active TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.tab-option:pointerover TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        </Style>

    </UserControl.Styles>

    <Border BorderThickness="1,0,0,0"
            Width="400"
            BorderBrush="{StaticResource BrushBorder}"
            Background="{StaticResource BrushPrimaryBackground}"
            IsVisible="{Binding State.HasItem}">

        <Grid RowDefinitions="Auto,*">

            <!-- Toggle header strip -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrushPrimaryBackgroundLight}">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="3">

                    <Button Grid.Column="0"
                            Classes="tab-option"
                            Classes.active="{Binding State.IsEntryTab}"
                            Command="{Binding SelectEntryTabCommand}">
                        <TextBlock Text="Entry"/>
                    </Button>

                    <Button Grid.Column="1"
                            Classes="tab-option"
                            Classes.active="{Binding State.IsActivityTab}"
                            Command="{Binding SelectActivityTabCommand}">
                        <TextBlock Text="Activity"/>
                    </Button>

                </Grid>
            </Border>

            <!-- Content area -->
            <ScrollViewer Grid.Row="1">
                <Panel>
                    <ContentControl Content="{Binding Entry}"
                                    IsVisible="{Binding State.IsEntryTab}"/>
                    <ContentControl Content="{Binding Activity}"
                                    IsVisible="{Binding State.IsActivityTab}"/>
                </Panel>
            </ScrollViewer>

        </Grid>

    </Border>
</UserControl>
