<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Misa.Ui.Avalonia.Features.Inspector.Root.InspectorFacadeView"
             xmlns:root="clr-namespace:Misa.Ui.Avalonia.Features.Inspector.Root"
             x:DataType="root:InspectorFacadeViewModel">
    
    <UserControl.Styles>
        <Style Selector="TabControl.inspector-tabs">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TabControl.inspector-tabs TabItem">
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
        
        <Style Selector="Border.inspector-tabs-underline">
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        </Style>
        
        <Style Selector="TabControl.inspector-tabs TabItem:pointerover">
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        </Style>

        <Style Selector="TabControl.inspector-tabs TabItem:selected">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        
        <Style Selector="TabControl.inspector-tabs TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>
    
    <Border BorderThickness="1,0,0,0"
            BorderBrush="{StaticResource BrushBorder}"
            Background="{StaticResource BrushPrimaryBackground}"
            IsVisible="{Binding State.HasItem}">

        <TabControl Classes="inspector-tabs"
                    SelectedIndex="{Binding State.SelectedTabIndex}">

            <TabItem Header="Entry">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="inspector-tabs-underline"/>

                    <ScrollViewer Grid.Row="1">
                        <ContentControl Content="{Binding Entry}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Discussion">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="inspector-tabs-underline"/>

                    <ScrollViewer Grid.Row="1">
                        <TextBlock Text="Discussion content placeholder"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <TabItem Header="Activity">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="inspector-tabs-underline"/>

                    <ScrollViewer Grid.Row="1">
                        <ContentControl Content="{Binding Activity}"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>