<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Misa.Ui.Avalonia.Features.Utilities.Notifications.NotificationView"
             xmlns:local="clr-namespace:Misa.Ui.Avalonia.Features.Utilities.Notifications"
             x:DataType="local:NotificationViewModel">

    <Border Classes="notif-panel"
            BorderThickness="1,0,0,0"
            BorderBrush="{StaticResource BrushBorder}">
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Border Grid.Row="0" Classes="notif-header">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                    <TextBlock Grid.Column="0"
                               Classes="notif-header-title"
                               Text="Notifications" />

                    <!-- Unread count badge -->
                    <Border Grid.Column="1"
                            Classes="notif-count-badge"
                            Margin="8,0,0,0"
                            IsVisible="{Binding HasUnread}">
                        <TextBlock Classes="notif-count-text"
                                   Text="{Binding UnreadCount}" />
                    </Border>

                    <!-- Mark all read -->
                    <Button Grid.Column="3"
                            Classes="notif-header-action"
                            ToolTip.Tip="Mark all as read"
                            Command="{Binding MarkAllReadCommand}"
                            IsVisible="{Binding HasUnread}">
                        <TextBlock Text="✓" FontSize="13" />
                    </Button>

                    <!-- Refresh -->
                    <Button Grid.Column="4"
                            Classes="notif-header-action"
                            ToolTip.Tip="Refresh"
                            Command="{Binding RefreshCommand}">
                        <TextBlock Text="↻" FontSize="14" />
                    </Button>

                </Grid>
            </Border>

            <!-- ── Filter bar ───────────────────────────────────────────── -->
            <Border Grid.Row="1" Classes="notif-filter-bar">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="notif-filter-tab"
                            Classes.active="{Binding IsFilterAll}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:NotificationFilter.All}"
                            Content="All" />
                    <Button Classes="notif-filter-tab"
                            Classes.active="{Binding IsFilterUnread}"
                            Command="{Binding SetFilterCommand}"
                            CommandParameter="{x:Static local:NotificationFilter.Unread}"
                            Content="Unread" />
                </StackPanel>
            </Border>

            <!-- ── List ────────────────────────────────────────────────── -->
            <Border Grid.Row="2" Classes="notif-list-area">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="0">
                        <!-- Empty state -->
                        <TextBlock Classes="notif-empty-text"
                                   Text="No notifications"
                                   IsVisible="{Binding IsEmpty}" />

                        <!-- Notification cards -->
                        <ItemsControl ItemsSource="{Binding Notifications}"
                                      IsVisible="{Binding !IsEmpty}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:NotificationItem">
                                    <Button Classes="notif-card"
                                            Command="{Binding $parent[ItemsControl].((local:NotificationViewModel)DataContext).MarkAsReadCommand}"
                                            CommandParameter="{Binding Id}">
                                        <Panel>

                                            <!-- Normal card content -->
                                            <Grid ColumnDefinitions="Auto,*"
                                                  IsVisible="{Binding !IsPendingDismiss}">

                                                <!-- Left accent strip (visible only when unread) -->
                                                <Border Grid.Column="0"
                                                        Classes="notif-card-accent"
                                                        IsVisible="{Binding !IsRead}" />

                                                <!-- Content -->
                                                <Border Grid.Column="1"
                                                        Classes="notif-card-body">
                                                    <Grid RowDefinitions="Auto,Auto"
                                                          ColumnDefinitions="*,Auto">

                                                        <!-- Title (bold when unread) -->
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Classes="notif-card-title"
                                                                   Classes.notif-card-title-unread="{Binding !IsRead}"
                                                                   Text="{Binding Title}" />

                                                        <!-- Dismiss -->
                                                        <Button Grid.Row="0" Grid.Column="1"
                                                                Grid.RowSpan="2"
                                                                Classes="notif-dismiss"
                                                                ToolTip.Tip="Dismiss"
                                                                VerticalAlignment="Top"
                                                                Margin="8,0,0,0"
                                                                Command="{Binding $parent[ItemsControl].((local:NotificationViewModel)DataContext).DismissCommand}"
                                                                CommandParameter="{Binding Id}">
                                                            <TextBlock Text="×" FontSize="13" />
                                                        </Button>

                                                        <!-- Message + timestamp -->
                                                        <Grid Grid.Row="1" Grid.Column="0"
                                                              RowDefinitions="Auto,Auto"
                                                              Margin="0,2,0,0">

                                                            <TextBlock Grid.Row="0"
                                                                       Classes="notif-card-message"
                                                                       Text="{Binding Message}"
                                                                       IsVisible="{Binding HasMessage}" />

                                                            <TextBlock Grid.Row="1"
                                                                       Classes="notif-card-time"
                                                                       Text="{Binding TimestampFormatted}"
                                                                       Margin="0,4,0,0" />
                                                        </Grid>

                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <!-- Undo banner (shown while dismiss is pending) -->
                                            <Border Classes="notif-undo-bar"
                                                    IsVisible="{Binding IsPendingDismiss}">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Classes="notif-undo-text"
                                                               Text="Dismissed"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Classes="notif-undo-btn"
                                                            Command="{Binding $parent[ItemsControl].((local:NotificationViewModel)DataContext).UndoDismissCommand}"
                                                            CommandParameter="{Binding Id}"
                                                            Content="Undo" />
                                                </Grid>
                                            </Border>

                                        </Panel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Classes="notif-load-more"
                                Command="{Binding LoadMoreCommand}"
                                IsVisible="{Binding HasMore}"
                                Content="Load more" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Border>

</UserControl>
