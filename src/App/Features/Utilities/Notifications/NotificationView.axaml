<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Misa.Ui.Avalonia.Features.Utilities.Notifications.NotificationView"
             xmlns:local="clr-namespace:Misa.Ui.Avalonia.Features.Utilities.Notifications"
             x:DataType="local:NotificationViewModel">

    <Border Classes="notif-panel">
        <Grid RowDefinitions="Auto,*">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Border Grid.Row="0" Classes="notif-header">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto">

                    <TextBlock Grid.Column="0"
                               Classes="notif-header-title"
                               Text="Notifications" />

                    <!-- Count badge -->
                    <Border Grid.Column="1"
                            Classes="notif-count-badge"
                            Margin="8,0,0,0"
                            IsVisible="{Binding !IsEmpty}">
                        <TextBlock Classes="notif-count-text"
                                   Text="{Binding Notifications.Count}" />
                    </Border>

                    <!-- Mark all read -->
                    <Button Grid.Column="2"
                            HorizontalAlignment="Right"
                            Classes="notif-header-action"
                            ToolTip.Tip="Mark all as read"
                            Command="{Binding MarkAllReadCommand}"
                            IsVisible="{Binding !IsEmpty}">
                        <TextBlock Text="✓" FontSize="13" />
                    </Button>

                    <!-- Refresh -->
                    <Button Grid.Column="3"
                            Classes="notif-header-action"
                            ToolTip.Tip="Refresh"
                            Command="{Binding RefreshCommand}">
                        <TextBlock Text="↻" FontSize="14" />
                    </Button>

                </Grid>
            </Border>

            <!-- ── List ────────────────────────────────────────────────── -->
            <Border Grid.Row="1" Classes="notif-list-area">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="4">
                        <!-- Empty state -->
                        <TextBlock Classes="notif-empty-text"
                                   Text="No notifications"
                                   IsVisible="{Binding IsEmpty}" />

                        <!-- Notification cards -->
                        <ItemsControl ItemsSource="{Binding Notifications}"
                                      IsVisible="{Binding !IsEmpty}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:NotificationItem">
                                    <Button Classes="notif-card"
                                            Command="{Binding $parent[ItemsControl].((local:NotificationViewModel)DataContext).MarkAsReadCommand}"
                                            CommandParameter="{Binding Id}">
                                        <Grid ColumnDefinitions="Auto,*">

                                            <!-- Left accent strip (visible only when unread) -->
                                            <Border Grid.Column="0"
                                                    Classes="notif-card-accent"
                                                    IsVisible="{Binding !IsRead}" />

                                            <!-- Content -->
                                            <Border Grid.Column="1"
                                                    Classes="notif-card-body">
                                                <Grid RowDefinitions="Auto,Auto"
                                                      ColumnDefinitions="*,Auto">

                                                    <!-- Title (bold when unread) -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Classes="notif-card-title"
                                                               Classes.notif-card-title-unread="{Binding !IsRead}"
                                                               Text="{Binding Title}" />

                                                    <!-- Dismiss -->
                                                    <Button Grid.Row="0" Grid.Column="1"
                                                            Grid.RowSpan="2"
                                                            Classes="notif-dismiss"
                                                            ToolTip.Tip="Dismiss"
                                                            VerticalAlignment="Top"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding $parent[ItemsControl].((local:NotificationViewModel)DataContext).DismissCommand}"
                                                            CommandParameter="{Binding Id}">
                                                        <TextBlock Text="×" FontSize="13" />
                                                    </Button>

                                                    <!-- Message + timestamp -->
                                                    <Grid Grid.Row="1" Grid.Column="0"
                                                          RowDefinitions="Auto,Auto"
                                                          Margin="0,2,0,0">

                                                        <TextBlock Grid.Row="0"
                                                                   Classes="notif-card-message"
                                                                   Text="{Binding Message}"
                                                                   IsVisible="{Binding HasMessage}" />

                                                        <TextBlock Grid.Row="1"
                                                                   Classes="notif-card-time"
                                                                   Text="{Binding TimestampFormatted}"
                                                                   Margin="0,4,0,0" />
                                                    </Grid>

                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Button Classes="notif-load-more"
                                Command="{Binding LoadMoreCommand}"
                                IsEnabled="True"
                                Content="Load more" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Border>

</UserControl>
