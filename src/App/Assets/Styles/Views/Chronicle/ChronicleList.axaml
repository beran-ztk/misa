<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Outer body ───────────────────────────────────────────────────── -->
    <Style Selector="Border.chronicle-outer-body">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}" />
    </Style>

    <!-- ── Day header ───────────────────────────────────────────────────── -->
    <Style Selector="Border.chronicle-daily-header">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBackground}" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="0,1" />

        <Style Selector="^ TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
    </Style>

    <Style Selector="Border.chronicle-daily-header.chronicle-today">
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />

        <Style Selector="^ TextBlock">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Style>

    <Style Selector="Border.chronicle-daily-header.chronicle-upcoming">
        <Setter Property="Background" Value="#08FFFFFF" />
    </Style>

    <!-- Upcoming badge -->
    <Style Selector="Border.chronicle-upcoming-badge">
        <Setter Property="Background" Value="#10FFFFFF" />
        <Setter Property="BorderBrush" Value="#20FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="7,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.chronicle-upcoming-badge-text">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Opacity" Value="0.6" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Entry row ────────────────────────────────────────────────────── -->
    <Style Selector="Border.chronicle-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="14,6" />
    </Style>

    <Style Selector="TextBlock.chronicle-row-title">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style Selector="TextBlock.chronicle-row-time">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.chronicle-row-meta">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Opacity" Value="0.75" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style Selector="TextBlock.chronicle-row-description">
        <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxLines" Value="2" />
        <Setter Property="Margin" Value="0,1,0,0" />
    </Style>

    <!-- ── Type chip (display, read-only) ───────────────────────────────── -->
    <Style Selector="Border.chronicle-type-chip">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="7,2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.chronicle-type-chip-text">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Opacity" Value="0.9" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Meta chip ────────────────────────────────────────────────────── -->
    <Style Selector="Border.chronicle-meta-chip">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.chronicle-meta-chip-text">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Opacity" Value="0.85" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Filter chip buttons (interactive toggles) ────────────────────── -->
    <Style Selector="Button.chronicle-filter-chip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="8,3" />
    </Style>

    <Style Selector="Button.chronicle-filter-chip:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#0AFFFFFF" />
    </Style>

    <Style Selector="Button.chronicle-filter-chip.selected">
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="#38FFFFFF" />
    </Style>

    <Style Selector="Button.chronicle-filter-chip.selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#22FFFFFF" />
    </Style>

    <!-- ── Date filter pickers ──────────────────────────────────────────── -->
    <Style Selector="DatePicker.chronicle-date-filter">
        <Setter Property="FontSize" Value="12" />
    </Style>

</Styles>
