<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://App/Assets/Styles/Views/Navigation/NavigationButtons.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
    
    <Style Selector="Image.utility-nav">
        <Setter Property="Stretch" Value="Uniform"/>    
    </Style>
    
    <Style Selector="Button.utility-nav">
        <Setter Property="Width" Value="33"/>
        <Setter Property="Height" Value="33"/>
        <Setter Property="Background" Value="Transparent"/>
            
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <Style Selector="Button.utility-nav:pointerover">
        <Setter Property="Opacity" Value="0.7"/>
    </Style>
    
    <Style Selector="Button.utility-nav:pressed">
        <Setter Property="RenderTransform" Value="scale(0.85)"/>
    </Style>
    
    <Style Selector="Button.utility-nav /template/ ContentPresenter">
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButtons}"/>
    </Style>
    
    <Style Selector="Button.utility-nav:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushNavigationHover}" />
    </Style>
    
    <Style Selector="Button.utility-nav:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource BrushNavigationPressed}" />
    </Style>

    <!-- ── Notification count badge ──────────────────────────────────────── -->
    <Style Selector="Border.notif-badge">
        <Setter Property="Background"      Value="#3B82F6"/>
        <Setter Property="CornerRadius"    Value="999"/>
        <Setter Property="Padding"         Value="3,0"/>
        <Setter Property="MinWidth"        Value="14"/>
        <Setter Property="Height"          Value="14"/>
        <Setter Property="Margin"          Value="0,0,0,0"/>
    </Style>

    <Style Selector="TextBlock.notif-badge-text">
        <Setter Property="Foreground"           Value="White"/>
        <Setter Property="FontSize"             Value="8"/>
        <Setter Property="FontWeight"           Value="Bold"/>
        <Setter Property="HorizontalAlignment"  Value="Center"/>
        <Setter Property="VerticalAlignment"    Value="Center"/>
        <Setter Property="TextAlignment"        Value="Center"/>
    </Style>

</Styles>
