<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Panel shell ──────────────────────────────────────────────────── -->
    <Style Selector="Border.notif-panel">
        <Setter Property="Background"   Value="{StaticResource BrushPrimaryBackgroundLight}" />
        <Setter Property="MinWidth"     Value="320" />
        <Setter Property="MaxWidth"     Value="480" />
    </Style>

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <Style Selector="Border.notif-header">
        <Setter Property="Background"       Value="{StaticResource BrushPrimaryBackground}" />
        <Setter Property="Padding"          Value="16,11" />
        <Setter Property="BorderBrush"      Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness"  Value="0,0,0,1" />
    </Style>

    <Style Selector="TextBlock.notif-header-title">
        <Setter Property="Foreground"   Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontSize"     Value="13" />
        <Setter Property="FontWeight"   Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.notif-count-badge">
        <Setter Property="Background"       Value="#18FFFFFF" />
        <Setter Property="BorderBrush"      Value="#28FFFFFF" />
        <Setter Property="BorderThickness"  Value="1" />
        <Setter Property="CornerRadius"     Value="999" />
        <Setter Property="Padding"          Value="6,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.notif-count-text">
        <Setter Property="Foreground"   Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize"     Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Header icon buttons -->
    <Style Selector="Button.notif-header-action">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="BorderBrush"      Value="Transparent" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Padding"          Value="6,4" />
        <Setter Property="FontSize"         Value="12" />
        <Setter Property="Opacity"          Value="0.6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor"           Value="Hand" />

        <Style Selector="^ /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="^:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#10FFFFFF" />
        </Style>
        <Style Selector="^:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#18FFFFFF" />
        </Style>
    </Style>

    <!-- ── List area ────────────────────────────────────────────────────── -->
    <Style Selector="Border.notif-list-area">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}" />
    </Style>

    <!-- ── Empty state ──────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.notif-empty-text">
        <Setter Property="Foreground"           Value="{StaticResource BrushTextFaded}" />
        <Setter Property="FontSize"             Value="13" />
        <Setter Property="Opacity"              Value="0.5" />
        <Setter Property="HorizontalAlignment"  Value="Center" />
        <Setter Property="VerticalAlignment"    Value="Center" />
        <Setter Property="TextAlignment"        Value="Center" />
        <Setter Property="Margin"               Value="0,32" />
    </Style>

    <!-- ── Notification card ────────────────────────────────────────────── -->
    <Style Selector="Border.notif-card">
        <Setter Property="Background"       Value="{StaticResource BrushPrimaryBackground}" />
        <Setter Property="BorderBrush"      Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness"  Value="0,0,0,1" />
        <Setter Property="Padding"          Value="0" />
    </Style>

    <Style Selector="Border.notif-card:pointerover">
        <Setter Property="Background" Value="#08FFFFFF" />
    </Style>

    <!-- Left accent strip -->
    <Style Selector="Border.notif-card-accent">
        <Setter Property="Background"   Value="{StaticResource BrushAccent}" />
        <Setter Property="Width"        Value="3" />
        <Setter Property="Opacity"      Value="0.7" />
    </Style>

    <!-- Card body padding -->
    <Style Selector="Border.notif-card-body">
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <!-- Card title -->
    <Style Selector="TextBlock.notif-card-title">
        <Setter Property="Foreground"       Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="FontSize"         Value="13" />
        <Setter Property="FontWeight"       Value="Medium" />
        <Setter Property="TextWrapping"     Value="NoWrap" />
        <Setter Property="TextTrimming"     Value="CharacterEllipsis" />
    </Style>

    <!-- Card message -->
    <Style Selector="TextBlock.notif-card-message">
        <Setter Property="Foreground"   Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="FontSize"     Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxLines"     Value="2" />
        <Setter Property="Opacity"      Value="0.85" />
        <Setter Property="Margin"       Value="0,2,0,0" />
    </Style>

    <!-- Card timestamp -->
    <Style Selector="TextBlock.notif-card-time">
        <Setter Property="Foreground"       Value="{StaticResource BrushTextFaded}" />
        <Setter Property="FontSize"         Value="11" />
        <Setter Property="Opacity"          Value="0.6" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
    </Style>

    <!-- Dismiss button -->
    <Style Selector="Button.notif-dismiss">
        <Setter Property="Background"       Value="Transparent" />
        <Setter Property="BorderBrush"      Value="Transparent" />
        <Setter Property="BorderThickness"  Value="0" />
        <Setter Property="Padding"          Value="4" />
        <Setter Property="Width"            Value="22" />
        <Setter Property="Height"           Value="22" />
        <Setter Property="Opacity"          Value="0" />
        <Setter Property="Foreground"       Value="{StaticResource BrushTextSecondary}" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Cursor"           Value="Hand" />

        <Style Selector="^ /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
    </Style>

    <!-- Show dismiss on card hover -->
    <Style Selector="Border.notif-card:pointerover Button.notif-dismiss">
        <Setter Property="Opacity" Value="0.7" />
    </Style>
    <Style Selector="Border.notif-card:pointerover Button.notif-dismiss:pointerover">
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- Local-only hint below list -->
    <Style Selector="TextBlock.notif-local-hint">
        <Setter Property="Foreground"           Value="{StaticResource BrushTextFaded}" />
        <Setter Property="FontSize"             Value="11" />
        <Setter Property="Opacity"              Value="0.4" />
        <Setter Property="HorizontalAlignment"  Value="Center" />
        <Setter Property="Margin"               Value="0,8,0,10" />
        <Setter Property="TextAlignment"        Value="Center" />
    </Style>

</Styles>
