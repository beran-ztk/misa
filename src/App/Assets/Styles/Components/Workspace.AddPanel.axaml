<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        
        <!-- Layout -->
        <Style Selector="Border.addpanel-main-border">
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackground}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="BoxShadow" Value="0 8 32 0 #55000000"/>
        </Style>

        <Style Selector="Grid.addpanel-main-grid">
                <Setter Property="RowSpacing" Value="16"/>
        </Style>

        <Style Selector="StackPanel.addpanel-body">
                <Setter Property="Spacing" Value="16"/>
        </Style>
        
        <Style Selector="StackPanel.addpanel-controls">
                <Setter Property="Spacing" Value="4"/>
        </Style>
        
        <Style Selector="Border.panel-divider">
                <Setter Property="Height" Value="1"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="Background" Value="{DynamicResource BrushBorder}"/>
                <Setter Property="Opacity" Value="0.30"/>
        </Style>

        <!-- Close / icon button in panel/modal header -->
        <Style Selector="Button.addpanel-icon">
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>

                <Style Selector="^ /template/ ContentPresenter">
                        <Setter Property="CornerRadius" Value="3"/>
                </Style>
                <Style Selector="^:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#10FFFFFF"/>
                </Style>
                <Style Selector="^:pressed /template/ ContentPresenter">
                        <Setter Property="Background" Value="#1AFFFFFF"/>
                </Style>

                <Style Selector="^ Image">
                        <Setter Property="Width" Value="14" />
                        <Setter Property="Height" Value="14" />
                </Style>
        </Style>
        
        <!-- Form section header -->
        <Style Selector="TextBlock.form-section-header">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Content -->
        <Style Selector="TextBlock.addpanel-text">
                <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushTextFaded}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        
        <!-- Single-Line Textbox -->
        <Style Selector="TextBox.addpanel-oneliner">
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="MinWidth" Value="300"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <!-- Multi-Line Textbox -->
        <Style Selector="TextBox.addpanel-multiline">
                <Setter Property="MinHeight" Value="90"/>
                <Setter Property="MinWidth" Value="300"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Combo-Box -->
        <Style Selector="ComboBox.addpanel-combo">
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="MinWidth" Value="180"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>

                <Setter Property="FontSize" Value="13"/>

                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        </Style>

        <!-- Numeric-Up-Down -->
        <Style Selector="NumericUpDown.addpanel-num">
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="MinWidth" Value="180"/>

                <Setter Property="FontSize" Value="13"/>

                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        </Style>

        <!-- Time -->
        <Style Selector="TimePicker.addpanel-time">
                <Setter Property="MinWidth" Value="300"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>

                <Setter Property="FontSize" Value="13"/>

                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        </Style>

        <!-- Date -->
        <Style Selector="DatePicker.addpanel-date">
                <Setter Property="MinWidth" Value="300"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>

                <Setter Property="FontSize" Value="13"/>

                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        </Style>
        
        <!-- Task template container inside CreateTask action -->
        <Style Selector="Border.addpanel-task-template">
                <Setter Property="Background" Value="#0AFFFFFF"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="14,12"/>
        </Style>

        <!-- Expander -->
        <Style Selector="Expander.addpanel-expander">
                <Setter Property="MinWidth" Value="180"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                
                <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}"/>
                
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Regular"/>
                
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                
                <!-- Header Background -->
                <Style Selector="^ ToggleButton /template/ Border">
                        <Setter Property="Background" Value="{StaticResource BrushBackgroundControl}"/>
                </Style>
                
                <!-- Checkbox as chip -->
                <Style Selector="^ CheckBox">
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{DynamicResource BrushTextFaded}"/>
                </Style>
        </Style>
        
</Styles>
