<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        workspace-toolbar-icon — small bordered icon button in workspace toolbars.

        Intentional differences from the global Button base:
        - Fixed 26×26 size with an 18×18 inner image
        - Starts at Opacity=0.5, lifts to 0.7 on hover (opacity-based dimming,
          not an alpha overlay, because the border must dim too)
        - Hover/pressed use BrushPrimaryBackgroundLighter (opaque surface lift)
          rather than alpha overlays — keeps the border visually stable
        - ContentPresenter has a visible 1px border (base provides none)
        - Pressed triggers a scale(0.85) micro-animation
    -->
    <Style Selector="Button.workspace-toolbar-icon">
        <Setter Property="Width"   Value="26"/>
        <Setter Property="Height"  Value="26"/>
        <Setter Property="Opacity" Value="0.5"/>

        <Style Selector="^ Image">
            <Setter Property="Width"  Value="18"/>
            <Setter Property="Height" Value="18"/>
        </Style>

        <Style Selector="^ /template/ ContentPresenter">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="scale(0.85)"/>
        </Style>
        <Style Selector="^:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>
    </Style>

</Styles>
