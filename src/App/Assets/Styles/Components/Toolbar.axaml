<!-- Toolbar spacing + Searchbar + Filter Trigger / Popup “sauber” -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.workspace-toolbar-frame">
        <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLight}" />
        <Setter Property="Padding" Value="18,12" />
    </Style>
    
    <Style Selector="Grid.workspace-toolbar">
        <Setter Property="RowSpacing" Value="8"/>
    </Style>

    <Style Selector="StackPanel.workspace-toolbar-left">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.workspace-toolbar-right">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="StackPanel.workspace-toolbar-center">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Spacing" Value="6" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Meta summary row -->
    <Style Selector="TextBlock.workspace-meta-summary">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <!-- Separator -->
    <Style Selector="Border.workspace-toolbar-separator">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource BrushBorder}" />
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Opacity" Value="0.40" />
    </Style>

</Styles>
