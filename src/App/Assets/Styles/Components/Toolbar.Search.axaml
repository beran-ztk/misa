<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        workspace-toolbar-search — fixed-size search box in workspace toolbars.

        Intentional differences from the global TextBox base:
        - Fixed 300×30 dimensions
    -->
    <Style Selector="TextBox.workspace-toolbar-search">
        <Setter Property="Width"   Value="300"/>
        <Setter Property="Height"  Value="30"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <Style Selector="TextBox.workspace-toolbar-search:pointerover, TextBox.workspace-toolbar-search:focus">
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
    </Style>
</Styles>
