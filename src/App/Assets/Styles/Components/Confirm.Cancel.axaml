<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="StackPanel.confirm-cancel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Spacing" Value="8"/>
    </Style>

    <Style Selector="Button.confirm-cancel-cancel">
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style Selector="^ /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0CFFFFFF"/>
        </Style>
    </Style>

    <Style Selector="Button.confirm-cancel-confirm">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{DynamicResource BrushAccent}"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style Selector="^ /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="^:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushAccentDim}"/>
        </Style>
        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
    </Style>

</Styles>
