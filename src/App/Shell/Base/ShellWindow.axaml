<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:base="clr-namespace:Misa.Ui.Avalonia.Shell.Base"
        x:Class="Misa.Ui.Avalonia.Shell.Base.ShellWindow"
        x:DataType="base:ShellWindowViewModel"
        Icon="/Assets/Icons/Shell/App/nanoparticle.png"
        Title="Misa"
        MinWidth="900"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

    <Window.KeyBindings>
        <!-- Utility -->
        <KeyBinding Gesture="Ctrl+N"     Command="{Binding UtilityNavigation.ToggleNotificationsCommand}"/>
        <KeyBinding Gesture="Escape"     Command="{Binding DismissCommand}"/>

        <!-- Workspace navigation -->
        <KeyBinding Gesture="Ctrl+D1"     Command="{Binding WorkspaceNavigation.ShowTasksCommand}"/>
        <KeyBinding Gesture="Ctrl+D2"     Command="{Binding WorkspaceNavigation.ShowSchedulerCommand}"/>
        <KeyBinding Gesture="Ctrl+D4"     Command="{Binding WorkspaceNavigation.ShowChronicleCommand}"/>
        <KeyBinding Gesture="Ctrl+D5"     Command="{Binding WorkspaceNavigation.ShowZettelkastenCommand}"/>

        <!-- Workspace actions -->
        <KeyBinding Gesture="Ctrl+Space" Command="{Binding WorkspaceAddCommand}"/>
        <KeyBinding Gesture="Ctrl+R"     Command="{Binding WorkspaceRefreshCommand}"/>
    </Window.KeyBindings>

    <Grid>
        
        <Grid x:Name="ShellLayer"
              ZIndex="10"
              RowDefinitions="40,*">
            
            <ContentControl Grid.Row="0" 
                            Content="{Binding ShellState.Header}"/>
            
            <Grid Grid.Row="1"
                  RowDefinitions="*,25">
                <Grid.ColumnDefinitions>
                    <!-- Auto: left navigation rail — width driven by WorkspaceNavigationView.NavWidth -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Flex: workspace is the sole star column and absorbs all remaining space -->
                    <ColumnDefinition Width="*"/>
                    <!-- Auto: inspector collapses to zero when not visible; MaxWidth caps growth -->
                    <ColumnDefinition Width="Auto" MaxWidth="450"/>
                    <!-- Auto: utility collapses to zero when not visible; MaxWidth caps growth -->
                    <ColumnDefinition Width="Auto" MaxWidth="600"/>
                    <!-- Fixed: right utility navigation rail -->
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Column="0"
                                Grid.Row="0" Grid.RowSpan="2"
                                Content="{Binding ShellState.WorkspaceNavigation}"/>

                <ContentControl Grid.Column="1"
                                Grid.Row="0"
                                Background="{StaticResource BrushPrimaryBackground}"
                                Content="{Binding ShellState.Workspace}"/>

                <ContentControl Grid.Column="2"
                                Grid.Row="0"
                                Content="{Binding ShellState.Inspector}"
                                IsVisible="{Binding ShellState.SelectionContextHasId}"/>

                <ContentControl Grid.Column="3"
                                Grid.Row="0"
                                Content="{Binding ShellState.Utility}"/>

                <ContentControl Grid.Column="4"
                                Grid.Row="0"
                                Content="{Binding ShellState.UtilityNavigation}"/>

                <ContentControl Grid.Column="1" Grid.ColumnSpan="4"
                                Grid.Row="1"
                                Content="{Binding ShellState.Footer}"/>
            </Grid>
        </Grid>
        
        <Grid x:Name="PanelLayer"
              ZIndex="20"
              IsVisible="{Binding ShellState.IsPanelOpen}">

            <!-- Overlay -->
            <Border Background="{StaticResource BrushOverlay}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Button Classes="overlay"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Command="{Binding LayerCloser.BackdropCloseCommand}"/>
            </Border>


            <!-- Panel content — fixed Width so no form or text can push the drawer wider -->
            <Border ZIndex="22"
                    Width="480"
                    Margin="0,0,75,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch">
                <ContentControl Content="{Binding ShellState.Panel}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"/>
            </Border>
        </Grid>

        
        <Grid x:Name="ModalLayer"
              ZIndex="30"
              IsVisible="{Binding ShellState.IsModalOpen}">

            <!-- Overlay -->
            <Border Background="{StaticResource BrushOverlay}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Button Classes="overlay"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Command="{Binding LayerCloser.BackdropCloseCommand}"/>
            </Border>

            <!--
                Modal viewport — the inner Grid carries the margin so that
                $parent[Grid].Bounds.Height returns the already-inset height
                (window minus the 64 px top/bottom safe zone).  Binding MaxHeight
                to that value means the modal can never be taller than the
                available space, and the LayerHostView ScrollViewer takes over
                for any content that does not fit.
            -->
            <Grid Margin="0,64,0,64">
                <Border ZIndex="32"
                        MinWidth="520"
                        MaxWidth="720"
                        MaxHeight="{Binding $parent[Grid].Bounds.Height, FallbackValue=800}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                    <ContentControl Content="{Binding ShellState.Modal}" />
                </Border>
            </Grid>
        </Grid>

        
        <Grid x:Name="ToastLayer"
              ZIndex="40">
            <ItemsControl ItemsSource="{Binding ShellState.Toasts}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,50,34"
                          IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8"
                                    IsHitTestVisible="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}"
                                        IsHitTestVisible="True"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
        
        <Grid x:Name="ActionToastLayer"
              ZIndex="45"
              IsHitTestVisible="False">
            <ItemsControl ItemsSource="{Binding ShellState.ActionToasts}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,16,0,0"
                          IsHitTestVisible="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8"
                                    IsHitTestVisible="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}"
                                        IsHitTestVisible="True"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <Grid x:Name="BusyLayer"
              ZIndex="50">
            <ContentControl Content="{Binding ShellState.Busy}"/>
        </Grid>
        
    </Grid>
</Window>
