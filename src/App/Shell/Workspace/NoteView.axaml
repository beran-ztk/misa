<UserControl xmlns="https://github.com/avaloniaui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.App.Shell.Workspace.NoteView"
             xmlns:root="clr-namespace:Misa.App.Shell.Workspace"
             xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
             x:DataType="root:NoteViewModel">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="16,*" Margin="30,16,24,0">
            <Ellipse Grid.Column="0"
                     Width="6" Height="6"
                     Fill="{StaticResource BrushAccent}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     IsVisible="{Binding IsDirty}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="{StaticResource FontSizeXLarge}"
                       FontWeight="SemiBold"
                       Opacity="0.9"
                       Foreground="{StaticResource BrushTextPrimary}"
                       TextWrapping="Wrap"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <avaloniaEdit:TextEditor x:Name="Editor"
                                         ShowLineNumbers="True"
                                         WordWrap="True"
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Disabled"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource BrushTextPrimary}"
                                         LineNumbersForeground="{StaticResource BrushTextFaded}"
                                         FontFamily="Cascadia Code"
                                         FontSize="{StaticResource FontSizeMedium}"/>
                <Border Height="100"/>
                <Border BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BrushBorder}"
                        Margin="30,0"
                        Opacity="0.9"
                        Height="100"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>