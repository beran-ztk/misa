<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:root="clr-namespace:Misa.App.Shell.Workspace"
             x:DataType="root:ZettelViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Title row: dirty indicator + title -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="50,16,24,0">
            <Ellipse Grid.Column="0"
                     Width="6" Height="6"
                     Fill="{StaticResource BrushAccent}"
                     VerticalAlignment="Center"
                     Margin="0,4,10,0"
                     IsVisible="{Binding IsDirty}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="{StaticResource FontSizeXLarge}"
                       FontWeight="SemiBold"
                       Opacity="0.9"
                       Foreground="{StaticResource BrushTextPrimary}"
                       TextWrapping="Wrap"/>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <aedit:TextEditor x:Name="Editor"
                                  ShowLineNumbers="True"
                                  WordWrap="True"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource BrushTextPrimary}"
                                  LineNumbersForeground="{StaticResource BrushTextFaded}"
                                  FontFamily="Cascadia Code"
                                  FontSize="{StaticResource FontSizeMedium}"/>
                <Border Height="100"/>
                <Border BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource BrushBorder}"
                        Margin="30,0"
                        Opacity="0.9"
                        Height="100"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
