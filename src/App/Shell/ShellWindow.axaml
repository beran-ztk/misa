<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell1="clr-namespace:Misa.App.Shell"
        x:Class="Misa.App.Shell.ShellWindow"
        x:DataType="shell1:ShellWindowViewModel"
        Icon="/Assets/Icons/app-icon-notebook.png"
        Title="Misa"
        MinWidth="900"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

    <Grid>
        
        <Grid RowDefinitions="40,*">
            
            <ContentControl Grid.Row="0" 
                            Content="{Binding Header}"/>
            
            <Grid Grid.Row="1" 
                  ColumnDefinitions="300,1,*">

                <ContentControl Grid.Column="0"
                                Content="{Binding Navigation}"/>

                <GridSplitter Grid.Column="1"
                              Background="{StaticResource BrushBorder}"
                              Opacity="0.5"/>
                
                <ContentControl Grid.Column="2"
                                Background="{StaticResource BrushPrimaryBackground}"
                                Content="{Binding Workspace}"/>
            </Grid>
        </Grid>
        
    </Grid>
</Window>
