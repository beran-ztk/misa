<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Misa.Ui.Avalonia.Shell.Authentication.AuthenticationWindow"
        xmlns:authentication="clr-namespace:Misa.Ui.Avalonia.Shell.Authentication"
        x:DataType="authentication:AuthenticationWindowViewModel"
        Icon="/Assets/Icons/Shell/App/notebook.png"
        Width="900"
        Height="640"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

    <!-- https://www.flaticon.com/free-icon/book_3794883?related_id=3794883 -->
    
    <Window.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}"/>
        <KeyBinding Gesture="Ctrl+B" Command="{Binding BypassCommand}"/>
    </Window.KeyBindings>

    <Window.Styles>

        <!-- Primary action button (Sign in / Register) -->
        <Style Selector="Button.auth-primary">
            <Setter Property="Background"  Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Height"      Value="36"/>
            <Setter Property="MinWidth"    Value="100"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButtons}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushAccentDim}"/>
            </Style>
        </Style>

        <!-- Secondary action button (Close) -->
        <Style Selector="Button.auth-secondary">
            <Setter Property="Foreground"      Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="MinWidth"        Value="90"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusButtons}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushSelectedOverlay}"/>
            </Style>
        </Style>

        <!-- Inline link-style button (mode switch) -->
        <Style Selector="Button.auth-link">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Padding"    Value="2,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background"   Value="Transparent"/>
                <Setter Property="CornerRadius" Value="2"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Opacity" Value="0.75"/>
            </Style>
        </Style>

        <!-- Window control buttons — mirrors HeaderView -->
        <Style Selector="Button.wnd-ctrl">
            <Setter Property="Foreground"        Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Width"             Value="46"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FontSize"          Value="13"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="0"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPressedOverlay}"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#26FFFFFF"/>
            </Style>
        </Style>
        <Style Selector="Button.wnd-ctrl.close:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.wnd-ctrl.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C42B1C"/>
        </Style>
        <Style Selector="Button.wnd-ctrl.close:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#B01E10"/>
        </Style>

        <!-- De-emphasised dev/bypass button -->
        <Style Selector="Button.auth-bypass">
            <Setter Property="Foreground" Value="{StaticResource BrushTextFaded}"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Opacity"    Value="0.4"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Opacity" Value="0.7"/>
            </Style>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="40,*"
          Background="{StaticResource BrushPrimaryBackground}">

        <!-- Custom header — mirrors HeaderView chrome -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushPrimaryBackground}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BrushBorder}"
                Padding="12,0,0,0"
                PointerPressed="OnHeaderPointerPressed">
            <Grid ColumnDefinitions="*,Auto"
                  VerticalAlignment="Stretch">

                <!-- Left: App icon -->
                <Image Source="/Assets/Icons/Shell/App/notebook.png"
                       Height="22"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapInterpolationMode="HighQuality"/>

                <!-- Right: Window controls (minimize + close; no maximize on fixed-size window) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch">
                    <Button Classes="wnd-ctrl"
                            Click="OnMinimizeClick">
                        <TextBlock Text="&#x2500;" FontSize="13"/>
                    </Button>
                    <Button Classes="wnd-ctrl close"
                            Click="OnCloseClick">
                        <TextBlock Text="&#x2715;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Centered auth card -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushPrimaryBackgroundLight}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="36,30"
                Width="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="0">

                <!-- ── Header ──────────────────────────────────────────────── -->
                <StackPanel Margin="0,0,0,28">

                    <!-- Product label: small, faded, label-weight -->
                    <TextBlock Text="MISA"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushTextFaded}"
                               Opacity="0.5"
                               Margin="0,0,0,8"/>

                    <!-- Section heading: the actual user-facing title -->
                    <TextBlock Text="{Binding SubtitleText}"
                               FontSize="20"
                               FontWeight="Medium"
                               Foreground="{StaticResource BrushTextPrimary}"/>

                </StackPanel>

                <!-- ── Form fields ──────────────────────────────────────────── -->
                <StackPanel Spacing="14" Margin="0,0,0,16">

                    <StackPanel Spacing="5">
                        <TextBlock Text="Username"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <TextBox x:Name="UsernameField"
                                 Text="{Binding Username, Mode=TwoWay}"
                                 IsEnabled="{Binding IsNotBusy}">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SubmitCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Password"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                        <TextBox Text="{Binding Password, Mode=TwoWay}"
                                 PasswordChar="•"
                                 IsEnabled="{Binding IsNotBusy}">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding SubmitCommand}"/>
                            </TextBox.KeyBindings>
                        </TextBox>
                    </StackPanel>

                    <!-- Register-only fields — collapse when not in register mode -->
                    <StackPanel IsVisible="{Binding IsRegisterMode}" Spacing="14">

                        <StackPanel Spacing="5">
                            <TextBlock Text="Confirm password"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay}"
                                     PasswordChar="•"
                                     Watermark="Repeat password"
                                     IsEnabled="{Binding IsNotBusy}">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SubmitCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Email"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Text="{Binding Email, Mode=TwoWay}"
                                     IsEnabled="{Binding IsNotBusy}">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding SubmitCommand}"/>
                                </TextBox.KeyBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Time zone"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                            <ComboBox ItemsSource="{Binding TimeZoneIds}"
                                      SelectedItem="{Binding SelectedTimeZoneId, Mode=TwoWay}"
                                      IsEnabled="{Binding IsNotBusy}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>

                <!-- ── Error banner ─────────────────────────────────────────── -->
                <Border IsVisible="{Binding HasError}"
                        Margin="0,0,0,16"
                        Padding="12,9"
                        CornerRadius="0,4,4,0"
                        Background="#12F44336"
                        BorderBrush="{StaticResource BrushError}"
                        BorderThickness="3,0,0,0">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource BrushError}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- ── Mode switch ──────────────────────────────────────────── -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">

                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding IsLoginMode}">
                        <TextBlock Text="No account?"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextFaded}"
                                   VerticalAlignment="Center"/>
                        <Button Classes="auth-link"
                                Content="Create one"
                                Command="{Binding SetRegisterModeCommand}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding IsRegisterMode}">
                        <TextBlock Text="Already have an account?"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushTextFaded}"
                                   VerticalAlignment="Center"/>
                        <Button Classes="auth-link"
                                Content="Sign in"
                                Command="{Binding SetLoginModeCommand}"/>
                    </StackPanel>

                </StackPanel>

                <!-- ── Actions ──────────────────────────────────────────────── -->
                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                      ColumnSpacing="8">

                    <!-- Dev bypass: visually stepped back, far left -->
                    <Button Grid.Column="0"
                            Classes="auth-bypass"
                            Content="Bypass"
                            Command="{Binding BypassCommand}"
                            IsEnabled="{Binding IsNotBusy}"/>

                    <!-- spacer -->
                    <Border Grid.Column="1"/>

                    <!-- Secondary: dismiss -->
                    <Button Grid.Column="2"
                            Classes="auth-secondary"
                            Content="Close"
                            Command="{Binding CloseCommand}"
                            IsEnabled="{Binding IsNotBusy}"/>

                    <!-- Primary: submit -->
                    <Button Grid.Column="3"
                            Classes="auth-primary"
                            Content="{Binding PrimaryButtonText}"
                            Command="{Binding SubmitCommand}"
                            IsEnabled="{Binding CanSubmit}"/>

                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>
