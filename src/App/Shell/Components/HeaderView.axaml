<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:Misa.Ui.Avalonia.Shell.Components"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="40"
             x:DataType="components:HeaderViewModel"
             x:Class="Misa.Ui.Avalonia.Shell.Components.HeaderView">

    <UserControl.Styles>

        <!-- ── User trigger button ───────────────────────────────────── -->
        <Style Selector="Button.header-user">
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.header-user /template/ ContentPresenter">
            <Setter Property="CornerRadius"   Value="{StaticResource CornerRadiusButtons}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BrushBorder}"/>
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Padding"     Value="10,0"/>
        </Style>
        <Style Selector="Button.header-user:pointerover /template/ ContentPresenter">
            <Setter Property="Background"  Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderLight}"/>
        </Style>
        <Style Selector="Button.header-user:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrushPrimaryBackgroundLighter}"/>
        </Style>

        <!-- ── User menu dropdown items ──────────────────────────────── -->
        <!-- btn-menu-item covers: Foreground, FontSize, Stretch/Left alignment, hover/pressed states -->
        <Style Selector="Button.user-menu-item">
            <Setter Property="Padding" Value="10,7"/>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.4"/>
            </Style>
        </Style>

        <!-- Danger variant — logout -->
        <Style Selector="Button.user-menu-item.danger">
            <Setter Property="Foreground" Value="#A05858"/>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#10F44336"/>
            </Style>
        </Style>

        <!-- ── Window control buttons ────────────────────────────────── -->
        <Style Selector="Button.wnd-ctrl">
            <Setter Property="Foreground"        Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Width"             Value="46"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FontSize"          Value="13"/>
            <Style Selector="^ /template/ ContentPresenter">
                <Setter Property="CornerRadius" Value="0"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{StaticResource BrushPressedOverlay}"/>
            </Style>
            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="#26FFFFFF"/>
            </Style>
        </Style>

        <!-- Close button — red on hover -->
        <Style Selector="Button.wnd-ctrl.close:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.wnd-ctrl.close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C42B1C"/>
        </Style>
        <Style Selector="Button.wnd-ctrl.close:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#B01E10"/>
        </Style>

    </UserControl.Styles>

    <!--
        The outer Border is the drag region.
        PointerPressed → BeginMoveDrag (single drag)
        DoubleTapped   → ToggleMaximize
        Buttons capture their own pointer events so they do NOT trigger dragging.
    -->
    <Border Background="{StaticResource BrushPrimaryBackground}"
            Padding="12,0,0,0"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource BrushBorder}"
            PointerPressed="OnHeaderPointerPressed"
            DoubleTapped="OnHeaderDoubleTapped">

        <Grid ColumnDefinitions="*, Auto, Auto"
              VerticalAlignment="Stretch">

            <!-- Left: App icon -->
            <Image Source="/Assets/Icons/Shell/App/notebook.png"
                   Height="22"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapInterpolationMode="HighQuality"/>

            <!-- Centre-right: User button -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">

                <Button Classes="header-user">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Background="{StaticResource BrushPrimaryBackgroundLighter}"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    BoxShadow="0 4 20 2 #60000000"
                                    MinWidth="160"
                                    Padding="4">
                                <StackPanel Spacing="1">

                                    <!-- Profile — placeholder, not yet functional -->
                                    <Button Classes="user-menu-item btn-menu-item"
                                            IsEnabled="False">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Image Width="13" Height="13" Opacity="0.6"
                                                   Source="{SvgImage /Assets/Icons/Shell/Navigation/user.svg}"/>
                                            <TextBlock Text="Profile"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Separator -->
                                    <Border Height="1"
                                            Margin="6,4"
                                            Background="{StaticResource BrushBorder}"
                                            Opacity="0.6"/>

                                    <!-- Logout -->
                                    <Button Classes="user-menu-item danger btn-menu-item"
                                            Command="{Binding LogoutCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Image Width="13" Height="13" Opacity="0.7"
                                                   Source="{SvgImage /Assets/Icons/Shell/Navigation/sign-out.svg}"/>
                                            <TextBlock Text="Logout"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <!-- Button content: status dot + username -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="7"
                                Margin="0,5">
                        <Ellipse Width="7" Height="7"
                                 Fill="{StaticResource BrushAccent}"
                                 Opacity="0.75"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding UserState.Username}"
                                   FontSize="{StaticResource FontSizeAverage}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Far right: Window controls -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        Margin="15,0,0,0">

                <Button Classes="wnd-ctrl"
                        Click="OnMinimizeClick">
                    <TextBlock Text="&#x2500;" FontSize="13"/>
                </Button>

                <Button Classes="wnd-ctrl"
                        Click="OnMaximizeRestoreClick">
                    <TextBlock Text="&#x25A1;" FontSize="13"/>
                </Button>

                <Button Classes="wnd-ctrl close"
                        Click="OnCloseClick">
                    <TextBlock Text="&#x2715;" FontSize="13"/>
                </Button>

            </StackPanel>

        </Grid>
    </Border>

</UserControl>
