<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.App.Shell.Components.NavigationView"
             xmlns:root="clr-namespace:Misa.App.Shell.Components"
             x:DataType="root:NavigationViewModel">

    <DockPanel Background="{StaticResource BrushPrimaryBackground}">

        <!-- Create root topic -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,Auto"
              Margin="6,6,6,4">
            <TextBox Grid.Column="0"
                     Text="{Binding NewTopicTitle}"
                     Watermark="New topic…"/>
            <Button Grid.Column="1"
                    Command="{Binding CreateRootTopicCommand}"
                    Content="+"
                    Margin="4,0,0,0"
                    FontSize="{StaticResource FontSizeLarge}"
                    Foreground="{StaticResource BrushTextSecondary}"/>
        </Grid>

        <!-- Index tree -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Margin="2,0">

            <TreeView x:Name="KnowledgeIndexTree"
                      ItemsSource="{Binding IndexEntries}"
                      FontSize="{StaticResource FontSizeAverage}"
                      Background="{StaticResource BrushPrimaryBackground}"
                      DragDrop.AllowDrop="True">

                <TreeView.Styles>
                    <Style Selector="Border.index-entry-row">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="Border.index-entry-row:pointerover">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </TreeView.Styles>

                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <Border Classes="index-entry-row">
                            <TextBlock Text="{Binding Title}"
                                       Opacity="0.8"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>

            </TreeView>

        </ScrollViewer>

    </DockPanel>

</UserControl>
