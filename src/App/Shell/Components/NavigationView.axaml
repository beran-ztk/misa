<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="Misa.App.Shell.Components.NavigationView"
             xmlns:root="clr-namespace:Misa.App.Shell.Components"
             x:DataType="root:NavigationViewModel">

    <DockPanel Background="{StaticResource BrushPrimaryBackground}">

        <!-- Create root topic -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,Auto"
              Margin="6,6,6,4">
            <TextBox Grid.Column="0"
                     Text="{Binding NewTopicTitle}"
                     Watermark="New topic…"/>
            <Button Grid.Column="1"
                    Command="{Binding CreateRootTopicCommand}"
                    Content="+"
                    Margin="4,0,0,0"
                    FontSize="{StaticResource FontSizeLarge}"
                    Foreground="{StaticResource BrushTextSecondary}"/>
        </Grid>

        <!-- Index tree -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Margin="2,0">

            <TreeView x:Name="KnowledgeIndexTree"
                      ItemsSource="{Binding IndexEntries}"
                      FontSize="{StaticResource FontSizeAverage}"
                      Background="{StaticResource BrushPrimaryBackground}"
                      DragDrop.AllowDrop="True">

                <TreeView.Styles>
                    <Style Selector="Border.index-entry-row">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="Border.index-entry-row:pointerover">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <!-- Reveal add button only on hover -->
                    <Style Selector="Border.index-entry-row Button.add-child">
                        <Setter Property="Opacity" Value="0"/>
                    </Style>
                    <Style Selector="Border.index-entry-row:pointerover Button.add-child">
                        <Setter Property="Opacity" Value="1"/>
                    </Style>
                </TreeView.Styles>

                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="root:IndexEntry"
                                      ItemsSource="{Binding Children}">
                        <Border Classes="index-entry-row">
                            <Grid ColumnDefinitions="*,Auto">

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Title}"
                                           Opacity="0.8"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="1"
                                        Classes="add-child"
                                        Content="+"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource BrushTextFaded}"
                                        FontSize="{StaticResource FontSizeMedium}">
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedRight">
                                            <Border x:DataType="root:IndexEntry"
                                                    Background="{StaticResource BrushControlSurface}"
                                                    CornerRadius="{StaticResource CornerRadiusCard}"
                                                    Padding="12">
                                            <StackPanel Width="188"
                                                        Spacing="{StaticResource SpacingMedium}">

                                                <!-- Kind selector -->
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="{StaticResource SpacingSmall}">
                                                    <Button Classes="btn-seg"
                                                            Classes.active="{Binding IsTopicSelected}"
                                                            Content="Topic"
                                                            Command="{Binding SetKindTopicCommand}"/>
                                                    <Button Classes="btn-seg"
                                                            Classes.active="{Binding IsNoteSelected}"
                                                            Content="Zettel"
                                                            Command="{Binding SetKindNoteCommand}"/>
                                                    <Button Classes="btn-seg"
                                                            Classes.active="{Binding IsQuestSelected}"
                                                            Content="Quest"
                                                            Command="{Binding SetKindQuestCommand}"/>
                                                </StackPanel>

                                                <!-- Title input -->
                                                <TextBox Text="{Binding PendingTitle}"
                                                         Watermark="Title…"/>

                                                <!-- Confirm -->
                                                <Button Classes="btn-primary"
                                                        Content="Create"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding CreateChildCommand}"/>

                                            </StackPanel>
                                            </Border>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>

                            </Grid>
                        </Border>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>

            </TreeView>

        </ScrollViewer>

    </DockPanel>

</UserControl>
