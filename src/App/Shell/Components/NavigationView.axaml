<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="Misa.App.Shell.Components.NavigationView"
             xmlns:behaviors="clr-namespace:Misa.App.Common.Behaviors"
             xmlns:converters="clr-namespace:Misa.App.Common.Converters"
             xmlns:root="clr-namespace:Misa.App.Shell.Components"
             x:DataType="root:NavigationViewModel">

    <Border Background="{StaticResource BrushPrimaryBackground}"
            Padding="8">
        
        <StackPanel Spacing="{StaticResource SpacingLarge}"
                    Opacity="0.8">

            <!-- Create root topic -->
            <StackPanel Orientation="Horizontal"
                        Spacing="{StaticResource SpacingMedium}">
                <Button Command="{Binding CreateRootTopicCommand}">
                    <Image Width="18" Height="18"
                           Source="{SvgImage /Assets/Icons/folder-add.svg}"/>
                </Button>
            </StackPanel>

            <!-- Index tree -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Margin="2,0">

                <TreeView x:Name="KnowledgeIndexTree"
                          ItemsSource="{Binding IndexEntries}"
                          FontSize="{StaticResource FontSizeAverage}"
                          Background="{StaticResource BrushPrimaryBackground}"
                          DragDrop.AllowDrop="True">

                    <TreeView.Styles>
                        <Style Selector="Border.index-entry-row">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="Border.index-entry-row:pointerover">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <!-- Reveal add button only on hover -->
                        <Style Selector="Border.index-entry-row Button.add-child">
                            <Setter Property="Opacity" Value="0"/>
                        </Style>
                        <Style Selector="Border.index-entry-row:pointerover Button.add-child">
                            <Setter Property="Opacity" Value="1"/>
                        </Style>
                    </TreeView.Styles>

                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="root:IndexEntry"
                                          ItemsSource="{Binding Children}">
                            <Border Classes="index-entry-row">
                                <Grid ColumnDefinitions="18,*,22" ColumnSpacing="4">

                                    <!-- Type icon -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center">
                                        <Image Width="14" Height="14" Opacity="0.55"
                                               Source="{SvgImage /Assets/Icons/folder.svg}"
                                               IsVisible="{Binding Kind,
                                                       Converter={x:Static converters:KindEqualConverter.Instance}, ConverterParameter=Topic}"/>
                                        <Image Width="14" Height="14" Opacity="0.55"
                                               Source="{SvgImage /Assets/Icons/note-blank.svg}"
                                               IsVisible="{Binding Kind,
                                                       Converter={x:Static converters:KindEqualConverter.Instance}, ConverterParameter=Note}"/>
                                        <Image Width="14" Height="14" Opacity="0.55"
                                               Source="{SvgImage /Assets/Icons/question-mark.svg}"
                                               IsVisible="{Binding Kind,
                                                       Converter={x:Static converters:KindEqualConverter.Instance}, ConverterParameter=Quest}"/>
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               IsVisible="{Binding !IsRenaming}"
                                               Text="{Binding Title}"
                                               Opacity="0.8"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBox Grid.Column="0"
                                               IsVisible="{Binding IsRenaming}"
                                               Text="{Binding RenamedTitle, Mode=TwoWay}"
                                               Opacity="0.8"
                                               VerticalAlignment="Center"
                                               behaviors:FocusControlWhenVisible.FocusOnVisible="{Binding IsRenaming}">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding SubmitRenameCommand}"/>
                                            <KeyBinding Gesture="Escape" Command="{Binding CancelRenameCommand}"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>

                                    <Button Grid.Column="2"
                                            Classes="add-child"
                                            Content="+"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource BrushTextFaded}"
                                            FontSize="{StaticResource FontSizeSmall}">
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedRight">
                                                <Border x:DataType="root:IndexEntry"
                                                        Background="{StaticResource BrushControlSurface}"
                                                        CornerRadius="{StaticResource CornerRadiusCard}"
                                                        Padding="6">
                                                    <StackPanel MinWidth="180">
                                                        <StackPanel IsVisible="{Binding CanHaveChildren}">
                                                            <Button Content="Create Topic"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Command="{Binding CreateTopicCommand}" />

                                                            <Button Content="Create Note"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Command="{Binding CreateNoteCommand}" />

                                                            <Button Content="Create Quest"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Command="{Binding CreateQuestCommand}" />

                                                            <Separator Opacity="0.5"/>
                                                        </StackPanel>

                                                        <Button Content="Rename"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left"
                                                                Command="{Binding IntendToRenameCommand}" />
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                </Grid>
                            </Border>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>

            </ScrollViewer>

        </StackPanel>
    </Border>
</UserControl>
