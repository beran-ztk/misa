<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Misa.Ui.Avalonia.Shell.Components.UtilityNavigationView"
             x:DataType="components:UtilityNavigationViewModel"
             xmlns:components="clr-namespace:Misa.Ui.Avalonia.Shell.Components"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters">

    <UserControl.Resources>
        <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
    </UserControl.Resources>
    
    <Border Background="{StaticResource BrushPrimaryBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1,0,0,0">

        <StackPanel Spacing="8"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">

            <Button Classes="utility-nav"
                    ToolTip.Tip="Notifications"
                    Command="{Binding ToggleNotificationsCommand}">

                <Grid Height="20" Width="20">

                    <Image Classes="utility-nav"
                           Source="{SvgImage /Assets/Icons/Shell/Utility/bell.svg}" />

                    <Border Width="8"
                            Height="8"
                            CornerRadius="4"
                            Background="#3B82F6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,1,1,0"
                            IsVisible="{Binding NotificationViewModel.UnreadCount, Converter={StaticResource GreaterThanZeroConverter}}" />

                </Grid>

            </Button>

        </StackPanel>
    </Border>
</UserControl>