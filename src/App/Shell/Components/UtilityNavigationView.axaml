<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Misa.Ui.Avalonia.Shell.Components.UtilityNavigationView"
             x:DataType="components:UtilityNavigationViewModel"
             xmlns:components="clr-namespace:Misa.Ui.Avalonia.Shell.Components"
             xmlns:converters="clr-namespace:Misa.Ui.Avalonia.Common.Converters">

    <Border Background="{StaticResource BrushPrimaryBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1,0,0,0">

        <StackPanel Spacing="8"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">

            <Button Classes="utility-nav"
                    ToolTip.Tip="Notifications"
                    Command="{Binding ToggleNotificationsCommand}">

                <Grid Height="24" Width="24">

                    <Image Classes="utility-nav"
                           Source="{SvgImage /Assets/Icons/Shell/Utility/bell.svg}" />

                    <Border Classes="notif-badge"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            IsVisible="{Binding HasUnread}">
                        <TextBlock Classes="notif-badge-text"
                                   Text="{Binding BadgeText}"/>
                    </Border>

                </Grid>

            </Button>

            <Button Classes="utility-nav"
                    ToolTip.Tip="Dev Tools"
                    Command="{Binding ToggleDevToolsCommand}">
                <Image Classes="utility-nav"
                       Source="{SvgImage /Assets/Icons/Shell/Navigation/nut.svg}" />
            </Button>

        </StackPanel>
    </Border>
</UserControl>