<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Shell.Components.WorkspaceNavigationView"
             xmlns:components="clr-namespace:Misa.Ui.Avalonia.Shell.Components"
             x:DataType="components:WorkspaceNavigationViewModel">

    <Border Background="{StaticResource BrushPrimaryBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="0,0,1,0"
            Padding="4">

        <Grid RowDefinitions="*,Auto">

            <!-- ── Primary navigation items ─────────────────────────── -->
            <StackPanel Grid.Row="0"
                        Spacing="{StaticResource SpacingSmall}">

                <Button Classes="workspace-nav"
                        Classes.nav-active="{Binding IsTasksActive}"
                        ToolTip.Tip="Tasks"
                        Command="{Binding ShowTasksCommand}">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/list-dashes.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        Classes.nav-active="{Binding IsSchedulerActive}"
                        ToolTip.Tip="Scheduler"
                        Command="{Binding ShowSchedulerCommand}">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/calendar-dots.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        ToolTip.Tip="Contacts">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/users-three.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        Classes.nav-active="{Binding IsJournalActive}"
                        ToolTip.Tip="Journal"
                        Command="{Binding ShowJournalCommand}">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/notebook.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        Classes.nav-active="{Binding IsChronicleActive}"
                        ToolTip.Tip="Chronicle"
                        Command="{Binding ShowChronicleCommand}">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/hourglass.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        Classes.nav-active="{Binding IsZettelActive}"
                        ToolTip.Tip="Zettelkasten"
                        Command="{Binding ShowZettelkastenCommand}">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/scroll.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        ToolTip.Tip="Evidences">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/bookmarks.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        ToolTip.Tip="RSS Feed">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/rss.svg}"/>
                </Button>

                <Button Classes="workspace-nav"
                        ToolTip.Tip="URLs">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/paperclip.svg}"/>
                </Button>

            </StackPanel>

            <!-- ── Footer ───────────────────────────────────────────── -->
            <StackPanel Grid.Row="1"
                        Spacing="{StaticResource SpacingSmall}"
                        VerticalAlignment="Bottom">

                <Button Classes="workspace-nav"
                        ToolTip.Tip="Ledger">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/notebook.svg}"/>
                </Button>

                <Border Height="1"
                        Margin="0,8,0,8"
                        Background="{StaticResource BrushSecondaryBackground}"
                        Opacity="0.6"/>

                <Button Classes="workspace-nav"
                        ToolTip.Tip="Settings">
                    <Image Width="20" Height="20" Opacity="0.8"
                           Source="{SvgImage /Assets/Icons/Shell/Navigation/nut.svg}"/>
                </Button>

            </StackPanel>

        </Grid>
    </Border>

</UserControl>
