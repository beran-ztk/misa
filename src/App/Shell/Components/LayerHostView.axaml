<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Misa.Ui.Avalonia.Shell.Components.LayerHostView"
             xmlns:vm="clr-namespace:Misa.Ui.Avalonia.Shell.Components"
             x:DataType="vm:IPanelHostViewModel">
    
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SubmitCommand}"/>
    </UserControl.KeyBindings>

    <Border Classes="addpanel-main-border">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
              Classes="addpanel-main-grid">

            <!-- Header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8"
                  RowDefinitions="Auto,Auto">

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding FormTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrushTextPrimary}" />

                <!-- Close -->
                <Button Grid.Row="0"
                        Grid.Column="1"
                        Classes="addpanel-icon"
                        VerticalAlignment="Center"
                        Command="{Binding CloseCommand}">
                    <Image Source="{SvgImage /Assets/Icons/Common/cancel.svg}" />
                </Button>

                <!-- Description -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,4,0,0"
                           Classes="addpanel-text"
                           Text="{Binding FormDescription}"
                           IsVisible="{Binding FormDescription}" />
            </Grid>

            <!-- Separator -->
            <Border Grid.Row="1" 
                    Classes="panel-divider"/>

            <!-- Body -->
            <ScrollViewer Grid.Row="2" 
                          VerticalScrollBarVisibility="Auto">
                
                <ContentControl Padding="0"
                    Content="{Binding Form}"/>
            </ScrollViewer>
            
            <!-- Separator -->
            <Border Grid.Row="3" 
                    Classes="panel-divider"/>

            <!-- Footer -->
            <Grid Grid.Row="4"
                  Margin="0,4,0,0"
                  ColumnDefinitions="*,Auto"
                  VerticalAlignment="Center">
                
                <StackPanel Grid.Column="1" 
                            Classes="confirm-cancel">
                    
                    <Button Content="Cancel"
                            Classes="confirm-cancel-cancel"
                            Command="{Binding CloseCommand}"/>
                    <Button Content="Submit"
                            Classes="confirm-cancel-confirm"
                            Command="{Binding SubmitCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>